{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git push origin *)",
      "Bash(docker-compose *)",
      "Bash(docker ps*)",
      "Bash(docker logs *)",
      "Bash(docker run --rm *)",
      "Edit(apps/**)",
      "Edit(packages/**)",
      "Edit(scripts/**)",
      "Edit(evals/**)",
      "Edit(docs/**)",
      "Edit(infra/**)",
      "Edit(.github/**)",
      "Write(apps/**)",
      "Write(packages/**)",
      "Write(scripts/**)",
      "Write(evals/**)",
      "Write(docs/**)",
      "Write(infra/**)",
      "Write(.github/**)"
    ],
    "ask": ["Bash(*scripts/deploy/deploy.sh*)", "Bash(*deploy.sh*)"],
    "deny": [
      "Bash(git push --force*main*)",
      "Bash(git push origin main --force*)",
      "Bash(git push -f *main*)",
      "Bash(git push*--force-with-lease*main*)",
      "Bash(git push*--force-if-includes*main*)",
      "Bash(psql *prod*)",
      "Bash(*docker exec*qufox-postgres-prod*)",
      "Bash(*docker-compose exec*qufox-postgres-prod*)",
      "Bash(*docker compose exec*qufox-postgres-prod*)",
      "Bash(rm -rf /*)",
      "Edit(.env)",
      "Edit(.env.prod*)",
      "Write(.env)",
      "Write(.env.prod*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": ".claude/hooks/guard.sh" }]
      }
    ]
  }
}
