# === qufox env ===
NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=43001
API_URL=http://localhost:43001

# Web
WEB_PORT=45173
WEB_URL=http://localhost:45173

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://qufox:qufox@localhost:55432/qufox?schema=public

# Redis 7
REDIS_URL=redis://localhost:6379

# Auth — JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_ISSUER=qufox
JWT_AUDIENCE=qufox-web
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# CORS (comma separated)
CORS_ORIGINS=http://localhost:45173,http://localhost:5173

# argon2id tuning (OWASP 2023 baseline)
ARGON2_MEMORY_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Workspace / invites
INVITE_CODE_BYTES=16
WORKSPACE_SOFT_DELETE_GRACE_DAYS=30

# Outbox (domain events dispatcher)
OUTBOX_DISPATCH_INTERVAL_MS=250
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10

# Unread read-state (S21 · FR-RS-14): stampede 락 TTL(ms). 집계 미스 시
# unread:lock:{ws}:{user} 를 per-call 랜덤 토큰으로 SET NX PX 선점하는 시간.
# 락 선점자가 무거운 집계를 마치고 캐시를 채우는 동안 동시 호출자는 짧게
# 대기 후 캐시를 재조회한다. (0, 5000] 범위로 클램프되며 벗어나면 기본값
# 폴백. 기본 2000ms — 집계 P99 보다 길게 잡아 선점자 미완료 시 폴백이
# 너무 일찍 터지지 않게 한다.
UNREAD_LOCK_TTL=2000

# Messages (task-004)
MESSAGE_MAX_LENGTH=4000
MESSAGE_RATE_USER_WINDOW_MS=10000
MESSAGE_RATE_USER_MAX=30
MESSAGE_RATE_CHANNEL_MAX=60

# OTEL (stdout exporter in dev)
OTEL_SERVICE_NAME=qufox-api
OTEL_EXPORTER=stdout

# Deterministic seed namespace (uuid v5)
SEED_NAMESPACE=00000000-0000-0000-0000-000000000000
