# === qufox env ===
NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=43001
API_URL=http://localhost:43001

# Web
WEB_PORT=45173
WEB_URL=http://localhost:45173

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://qufox:qufox@localhost:55432/qufox?schema=public

# Redis 7
REDIS_URL=redis://localhost:6379

# Auth — JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_ISSUER=qufox
JWT_AUDIENCE=qufox-web
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# CORS (comma separated)
CORS_ORIGINS=http://localhost:45173,http://localhost:5173

# argon2id tuning (OWASP 2023 baseline)
ARGON2_MEMORY_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# S77b (D14 / FR-PS-15): TOTP 2FA 시크릿 암호화 키(AES-256-GCM). 32바이트를 base64 로
# 인코딩한 값(생성 예: `openssl rand -base64 32`). 미설정 시 모든 2FA 엔드포인트는
# graceful 503(ENCRYPTION_UNAVAILABLE)으로 응답한다(서버 크래시 금지). dev 는 아래 예시값
# 으로 충분하며, ★prod 키는 .env.prod 에 별도 강한 키로 설정한다(이 저장소엔 미작성). 시크릿
# 자체는 절대 로그에 남기지 않는다(CryptoService 가 강제).
#   security MED-1 fix-forward: dev 예시값을 평문이 "change-me-…" 로 시작하는 명백한 비-시크릿
#   플레이스홀더의 base64(32B)로 바꿔 gitleaks 오탐을 줄인다(.gitleaks.toml allowlist 와 이중).
#   평문 = "change-me-dev-only-totp-key-32by" (32B) → 아래 base64.
APP_ENCRYPTION_KEY=Y2hhbmdlLW1lLWRldi1vbmx5LXRvdHAta2V5LTMyYnk=

# Workspace / invites
INVITE_CODE_BYTES=16
WORKSPACE_SOFT_DELETE_GRACE_DAYS=30
# S72 (D13 / FR-W22): IP soft-block threshold. 멤버 ban 시 그 멤버의 마지막 가입 IP 해시가
# BannedMember.ipHash 로 복사되고, 같은 IP 의 PUBLIC/초대 가입은 허용하되 SUSPICIOUS_JOIN
# 감사 신호를 남긴다(NAT 공유 오탐 방지 — IP 는 hard-block 하지 않음). 동일 IP 해시의 24h
# 내 SUSPICIOUS_JOIN 누적이 이 값 이상이면 모더레이션 알림(SUSPICIOUS_JOIN_THRESHOLD)을
# 추가 기록한다. 기본 3. (APPLY 신청은 같은 IP 매칭 시 즉시 409(중립 APPLICATION_NOT_
# APPLICABLE)로 차단된다 — 차단 사실 누출을 막는 중립 코드.)
IP_BLOCK_THRESHOLD=3
# S72 (D13 / FR-W15): 워크스페이스 30일 grace purge 시 Message.authorId 를 이 시스템
# 사용자(SYSTEM_ANON)로 익명화한다(내용 보존, 작성자만 마스킹 — ADR-013 단일 정책).
# Message.authorId 는 User FK 라 익명화 대상 system User 행이 반드시 존재해야 하며,
# seed 와 purge 가 선행 idempotent insert 로 보장한다. 결정론적 uuid v5(SEED_NAMESPACE +
# 'user:system-anon')의 기본값이며, 별도 ID 를 쓰려면 여기서 덮어쓴다. 미설정 시 purge.sh /
# seed 가 기본 결정론 UUID 를 쓴다(아래 값은 SEED_NAMESPACE=00000000-... 기준 산출값).
ANON_AUTHOR_UUID=871aa8f6-f28a-5e26-ba8f-37ca7126e9e3

# Outbox (domain events dispatcher)
OUTBOX_DISPATCH_INTERVAL_MS=250
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10

# Unread read-state (S21 · FR-RS-14): stampede 락 TTL(ms). 집계 미스 시
# unread:lock:{ws}:{user} 를 per-call 랜덤 토큰으로 SET NX PX 선점하는 시간.
# 락 선점자가 무거운 집계를 마치고 캐시를 채우는 동안 동시 호출자는 짧게
# 대기 후 캐시를 재조회한다. (0, 5000] 범위로 클램프되며 벗어나면 기본값
# 폴백. 기본 2000ms — 집계 P99 보다 길게 잡아 선점자 미완료 시 폴백이
# 너무 일찍 터지지 않게 한다.
UNREAD_LOCK_TTL=2000

# Messages (task-004)
MESSAGE_MAX_LENGTH=4000
MESSAGE_RATE_USER_WINDOW_MS=10000
MESSAGE_RATE_USER_MAX=30
MESSAGE_RATE_CHANNEL_MAX=60

# Presence (S25 · FR-P01/P02/RT-10)
# PRESENCE_SESSION_TTL_SEC : WS 세션 Redis TTL(초). presence:ping 으로 갱신.
# PRESENCE_OFFLINE_GRACE   : 마지막 세션 끊김 후 OFFLINE 전환 grace(초, 기본 35).
# PRESENCE_IDLE_TIMEOUT    : 활동 없음 → IDLE 자동전환(초, 기본 600=10분).
# PRESENCE_IDLE_SWEEP_INTERVAL_MS : ONLINE→IDLE 감지 폴링 주기(ms, 기본 30000).
# PRESENCE_UPDATE_THROTTLE_MS : presence.updated 브로드캐스트 합치기 창(ms).
# PRESENCE_SUB_TTL_SEC        : (S26 · FR-P16) presence:subscribe 구독 Set 의
#                               disconnect 후 보존 TTL(초, 기본 300=5분).
# PRESENCE_SUBSCRIBE_BURST_MAX / _WINDOW_MS : (S26 · FR-RT-12) 동일 소켓
#                               presence:subscribe 버스트 상한(기본 10회/1000ms).
PRESENCE_SESSION_TTL_SEC=120
PRESENCE_OFFLINE_GRACE=35
PRESENCE_IDLE_TIMEOUT=600
PRESENCE_IDLE_SWEEP_INTERVAL_MS=30000
PRESENCE_UPDATE_THROTTLE_MS=2000
PRESENCE_SUB_TTL_SEC=300
PRESENCE_SUBSCRIBE_BURST_MAX=10
PRESENCE_SUBSCRIBE_BURST_WINDOW_MS=1000

# Typing (task-018-F · S26 · FR-P07/DM-14)
# TYPING_TTL_SEC      : 타이핑 SET Redis TTL(초, 기본 10 = 공유 TYPING_TTL).
# TYPING_THROTTLE_SEC : (user, channel) 당 ping 스로틀(초, 기본 3).
# TYPING_MAX_VISIBLE  : typing.updated 동시 표시 최대 인원(기본 3, "외 N명").
TYPING_TTL_SEC=10
TYPING_THROTTLE_SEC=3
TYPING_MAX_VISIBLE=3

# S79 (D15 / FR-SC-01): GIPHY 빌트인 슬래시 커맨드(/giphy)는 이 키가 설정된 경우에만
# 자동완성 목록에 노출된다(미설정 시 제외 — NAS 기본 비활성화). 실행(GIPHY 프록시)은
# S81. ★옵셔널 키이므로 일부러 주석 처리해 둔다 — scripts/verify-env.ts 는 '#' 로
# 시작하는 라인을 required 에서 제외하므로(주석 skip), 이 키가 .env 에 없어도 bootstrap
# 의 strict 검증을 깨지 않는다. /giphy 를 켜려면 아래 주석을 풀고 실제 GIPHY 키를 넣되,
# 시크릿은 .env(git-ignored)에만 두고 이 예시 파일에는 플레이스홀더조차 남기지 않는다.
# GIPHY_API_KEY=

# OTEL (stdout exporter in dev)
OTEL_SERVICE_NAME=qufox-api
OTEL_EXPORTER=stdout

# Deterministic seed namespace (uuid v5)
SEED_NAMESPACE=00000000-0000-0000-0000-000000000000
