# === qufox env ===
NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=43001
API_URL=http://localhost:43001

# Web
WEB_PORT=45173
WEB_URL=http://localhost:45173

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://qufox:qufox@localhost:55432/qufox?schema=public

# Redis 7
REDIS_URL=redis://localhost:6379

# Auth (TODO(task-001): JWT module)
JWT_ACCESS_SECRET=change-me-access-dev-only
JWT_REFRESH_SECRET=change-me-refresh-dev-only
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# OTEL (stdout exporter in dev)
OTEL_SERVICE_NAME=qufox-api
OTEL_EXPORTER=stdout

# Deterministic seed namespace (uuid v5)
SEED_NAMESPACE=00000000-0000-0000-0000-000000000000
