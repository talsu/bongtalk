# === qufox env ===
NODE_ENV=development
LOG_LEVEL=info

# API
API_PORT=43001
API_URL=http://localhost:43001

# Web
WEB_PORT=45173
WEB_URL=http://localhost:45173

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://qufox:qufox@localhost:55432/qufox?schema=public

# Redis 7
REDIS_URL=redis://localhost:6379

# Auth — JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_ISSUER=qufox
JWT_AUDIENCE=qufox-web
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800

# CORS (comma separated)
CORS_ORIGINS=http://localhost:45173,http://localhost:5173

# argon2id tuning (OWASP 2023 baseline)
ARGON2_MEMORY_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# Workspace / invites
INVITE_CODE_BYTES=16
WORKSPACE_SOFT_DELETE_GRACE_DAYS=30

# OTEL (stdout exporter in dev)
OTEL_SERVICE_NAME=qufox-api
OTEL_EXPORTER=stdout

# Deterministic seed namespace (uuid v5)
SEED_NAMESPACE=00000000-0000-0000-0000-000000000000
