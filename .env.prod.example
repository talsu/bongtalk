# Copy to .env.prod and fill in. This file is read by docker-compose.prod.yml.
POSTGRES_PASSWORD=change-me-strong-password
JWT_ACCESS_SECRET=change-me-64-hex-chars-or-more-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_ISSUER=qufox
JWT_AUDIENCE=qufox-web
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
ARGON2_MEMORY_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
INVITE_CODE_BYTES=16
WORKSPACE_SOFT_DELETE_GRACE_DAYS=30
OUTBOX_DISPATCH_INTERVAL_MS=250
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=10
LOG_LEVEL=info
OTEL_SERVICE_NAME=qufox-api
OTEL_EXPORTER=stdout
SEED_NAMESPACE=00000000-0000-0000-0000-000000000000

# --- task-012-F: MinIO object storage (attachments) ---------------------
# Root credentials for the MinIO server itself. `scripts/setup/init-minio.sh`
# uses these ONCE to create the app-scoped IAM user the API consumes; it
# does NOT store the root creds in the API container. Regenerate with
# `openssl rand -hex 24`.
MINIO_ROOT_USER=qufox-minio-root
MINIO_ROOT_PASSWORD=change-me-48-hex-chars

# --- task-012-B: S3 client (API → MinIO) --------------------------------
# The S3 SDK speaks the same protocol to MinIO as to AWS S3; endpoint
# + path-style addressing are the MinIO tells.
#
# task-012 reviewer HIGH-3 fix: two endpoints, not one.
# `S3_ENDPOINT` is the INTERNAL container URL (reachable only on the
# `internal` docker network) — API uses this for server-side
# HeadObject + DeleteObject. `S3_PUBLIC_ENDPOINT` is what the
# browser will hit (nginx-fronted `/attachments/`), and the presigner
# signs every URL against that host so the signed Host header
# matches the actual request. Leave S3_PUBLIC_ENDPOINT unset in dev
# to reuse S3_ENDPOINT for both (works when api + browser share the
# same origin).
S3_ENDPOINT=http://qufox-minio:9000
S3_PUBLIC_ENDPOINT=https://qufox.com/attachments
S3_REGION=us-east-1
S3_BUCKET=qufox-attachments
# App-scoped credentials issued by init-minio.sh — do NOT reuse the
# MINIO_ROOT_*. Regenerate via `mc admin user add qufox qufox-api …`.
S3_ACCESS_KEY_ID=qufox-api
S3_SECRET_ACCESS_KEY=change-me-40-chars
# Presign TTLs (seconds). Short PUT so a stale upload URL doesn't
# accept bytes forever; GET is 30 min so the lightbox can hold open.
S3_PRESIGN_PUT_TTL_SEC=900
S3_PRESIGN_GET_TTL_SEC=1800
S3_MAX_UPLOAD_BYTES=104857600
