{
  "title": "qufox — Realtime",
  "uid": "qufox-realtime",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-3h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "ds",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "title": "WS connections (active)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [{ "expr": "sum(ws_connections_active)" }],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "Fan-out latency p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ws_message_fanout_latency_seconds_bucket[5m])))"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "title": "Replay outcomes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [
        {
          "expr": "sum by (result) (rate(ws_replay_events_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "title": "Disconnect reasons",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(ws_disconnections_total[5m]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "title": "Presence sessions",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${ds}" },
      "targets": [{ "expr": "sum(ws_presence_sessions_active)" }],
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 }
    }
  ]
}
