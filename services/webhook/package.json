{
  "name": "@qufox/webhook",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub webhook receiver that triggers the production deploy scripts after HMAC + branch allowlist checks.",
  "main": "dist/main.js",
  "scripts": {
    "build": "swc src -d dist --copy-files --strip-leading-paths",
    "start": "node dist/main.js",
    "dev": "node --require @swc-node/register src/main.ts",
    "lint": "eslint src test --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@swc-node/register": "1.10.10",
    "@swc/cli": "0.7.8",
    "@swc/core": "1.10.11",
    "@types/node": "22.10.6",
    "typescript": "5.7.3",
    "unplugin-swc": "1.5.1",
    "vitest": "3.0.4"
  }
}
