// Prisma schema for qufox (Phase 0 bootstrap)
// Tables: User, Workspace, WorkspaceMember, Channel, Message, Invite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  TEXT
  VOICE
  ANNOUNCEMENT
}

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String
  aggregateId   String    @db.Uuid
  eventType     String
  payload       Json
  occurredAt    DateTime  @default(now())
  dispatchedAt  DateTime?
  attempts      Int       @default(0)
  lastError     String?

  @@index([dispatchedAt, occurredAt])
  @@index([aggregateType, aggregateId])
}

model User {
  id                  String    @id @db.Uuid
  email               String    @unique
  username            String    @unique
  passwordHash        String
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  messages        Message[]
  invitesCreated  Invite[]          @relation("InviteCreator")
  refreshTokens   RefreshToken[]
  attachments     Attachment[]
  reactions       MessageReaction[]
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  familyId   String    @db.Uuid
  parentId   String?   @db.Uuid
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model Workspace {
  id          String    @id @db.Uuid
  name        String
  slug        String    @unique
  description String?
  iconUrl     String?
  ownerId     String    @db.Uuid
  deletedAt   DateTime?
  deleteAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner      User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members    WorkspaceMember[]
  channels   Channel[]
  categories Category[]
  invites    Invite[]

  @@index([ownerId])
  @@index([deletedAt])
}

model WorkspaceMember {
  workspaceId String        @db.Uuid
  userId      String        @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  position    Decimal   @db.Decimal(20, 10)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  channels    Channel[]

  @@unique([workspaceId, name])
  @@index([workspaceId, position])
}

model Channel {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @db.Uuid
  categoryId  String?     @db.Uuid
  name        String
  type        ChannelType @default(TEXT)
  topic       String?
  position    Decimal     @db.Decimal(20, 10)
  isPrivate   Boolean     @default(false)
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category    Category?                   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages    Message[]
  attachments Attachment[]
  overrides   ChannelPermissionOverride[]

  @@unique([workspaceId, name])
  @@index([workspaceId, categoryId, position])
  @@index([workspaceId, deletedAt])
}

// Task-012-D: per-channel permission override. principalType = 'USER'
// (principalId = User.id UUID) or 'ROLE' (principalId = WorkspaceRole
// literal: OWNER/ADMIN/MEMBER). Masks are bitfields per
// apps/api/src/auth/permissions.ts; DENY > ALLOW.
model ChannelPermissionOverride {
  id            String   @id @default(uuid()) @db.Uuid
  channelId     String   @db.Uuid
  principalType String   @db.VarChar(8)
  principalId   String   @db.VarChar(64)
  allowMask     Int      @default(0)
  denyMask      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, principalType, principalId])
  @@index([channelId])
}

model Message {
  id             String    @id @default(uuid()) @db.Uuid
  channelId      String    @db.Uuid
  authorId       String    @db.Uuid
  content        String
  contentPlain   String
  mentions       Json      @default("{\"users\":[],\"channels\":[],\"everyone\":false}")
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // client-generated uuid for POST retry dedupe — null when no header was sent.
  // Uniqueness enforced by a PARTIAL unique index created in raw SQL
  // (schema-level `@@unique` would index every NULL row too, which we want
  // to skip since unauthenticated sends never carry a key).
  idempotencyKey String?   @db.Uuid
  // task-014-B: single-level threads. Self-FK; ON DELETE SET NULL means
  // a hard-deleted root turns its replies into pseudo-roots (purge
  // worker is the only path that hard-deletes). Soft delete leaves the
  // row intact and hides the content at the DTO layer. Single-level
  // depth is enforced at the service — parent-of-parent must be NULL.
  parentMessageId String?  @db.Uuid

  channel     Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author      User              @relation(fields: [authorId], references: [id])
  attachments Attachment[]
  reactions   MessageReaction[]
  parent      Message?          @relation("MessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies     Message[]         @relation("MessageReplies")

  // pagination primary path — matches ORDER BY createdAt DESC, id DESC with
  // row-value comparison WHERE (createdAt, id) < ($1, $2).
  @@index([channelId, createdAt, id])
  // includeDeleted=false default path (soft-delete filter).
  @@index([channelId, deletedAt, createdAt])
  @@index([authorId])
  // thread replies list — ORDER BY createdAt ASC for the ThreadPanel.
  // Partial index `(channelId, createdAt DESC) WHERE parentMessageId IS NULL`
  // + the replies index `(parentMessageId, createdAt ASC)` are defined in
  // the raw-SQL migration (Prisma's @@index doesn't support partial WHERE).
  @@index([parentMessageId, createdAt])
}

// Task-013-B: per-message reactions. `emoji` is the literal unicode
// string as picked; VARCHAR(64) gives room for ZWJ sequences. API
// enforces ≤4 codepoint cap on top. (messageId, userId, emoji) is
// unique so POST is naturally idempotent — see ReactionsService.
model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String   @db.VarChar(64)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId, emoji])
}

enum AttachmentKind {
  IMAGE
  VIDEO
  FILE
}

model Attachment {
  id                 String         @id @default(uuid()) @db.Uuid
  channelId          String         @db.Uuid
  messageId          String?        @db.Uuid
  uploaderId         String         @db.Uuid
  clientAttachmentId String?        @db.Uuid
  kind               AttachmentKind
  mime               String         @db.VarChar(127)
  sizeBytes          BigInt
  storageKey         String
  originalName       String
  finalizedAt        DateTime?
  createdAt          DateTime       @default(now())

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploaderId], references: [id])

  // Indexes are created in the migration as partial indexes (Prisma
  // has no @@index-with-WHERE syntax). See
  // 20260421000000_add_attachment_table/migration.sql.
}

model UserChannelReadState {
  userId          String   @db.Uuid
  channelId       String   @db.Uuid
  // Points at an OutboxEvent.id — the last event this user has fully
  // processed client-side. Drives reconnect replay ("replay everything after
  // X") and, later, the unread-count UI (TODO task-027).
  lastReadEventId String   @db.Uuid
  lastReadAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@id([userId, channelId])
  @@index([channelId])
}

model Invite {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  code        String    @unique
  createdById String    @db.Uuid
  expiresAt   DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([expiresAt])
}
