// Prisma schema for qufox (Phase 0 bootstrap)
// Tables: User, Workspace, WorkspaceMember, Channel, Message, Invite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// S61 (D12 / FR-RM01): 시스템 역할 계층을 3단계 → 5단계로 확장합니다
// (OWNER > ADMIN > MODERATOR > MEMBER > GUEST). MODERATOR/GUEST 는 신규
// 추가 값으로, 기존 row(OWNER/ADMIN/MEMBER)는 그대로 유지됩니다. PostgreSQL
// enum 은 값 DROP 이 불가하므로 down 마이그레이션 전략은 마이그레이션 파일
// 주석에 문서화합니다(신규값을 미사용 상태로 두고 down 에서 제거하지 않음).
enum WorkspaceRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
  GUEST
}

enum ChannelType {
  TEXT
  VOICE
  ANNOUNCEMENT
  FORUM
  DIRECT
}

// S01 (ADR-2): Message author classification. Default USER keeps every
// existing row valid without a backfill (DB default fills NULLs at add
// time). BOT / SYSTEM land in later slices (webhooks / system messages).
enum AuthorType {
  USER
  BOT
  SYSTEM
}

// S04 (ADR-2 / FR-MSG-19 / FR-RC10) — MessageType 단일 카노니컬 정의.
// 값 집합은 packages/shared-types/src/message-type.ts 와 1:1 동기화됩니다.
// SYSTEM_* 는 authorType=SYSTEM, grouped=false 강제, 편집·삭제 UI 미표시.
enum MessageType {
  DEFAULT
  SYSTEM_MEMBER_JOINED
  SYSTEM_MEMBER_LEFT
  SYSTEM_MEMBER_BANNED
  SYSTEM_PIN
  SYSTEM_CHANNEL_RENAME
  SYSTEM_CHANNEL_TOPIC_CHANGED
  SYSTEM_CHANNEL_ARCHIVED
  SYSTEM_THREAD_BROADCAST
}

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String
  aggregateId   String    @db.Uuid
  eventType     String
  payload       Json
  occurredAt    DateTime  @default(now())
  dispatchedAt  DateTime?
  attempts      Int       @default(0)
  lastError     String?

  @@index([dispatchedAt, occurredAt])
  @@index([aggregateType, aggregateId])
}

enum PresencePreference {
  auto
  dnd
  // S25 (FR-P01): 사용자가 스스로 숨김. 본인에게만 실제값, 타인에게는 offline 으로
  // 마스킹(maskPresenceForViewer). runtime presence(Redis)는 별개 — 이 enum 은
  // connect 시 게이트웨이가 읽는 정적 선호값이다.
  invisible
}

enum NotificationEventType {
  MENTION
  REPLY
  REACTION
  DIRECT
  FRIEND_REQUEST
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

// S38 (D04 / FR-TH-08): 스레드 구독 알림 레벨.
//   ALL      — 새 답글마다 thread:reply 알림 수신(기존 구독 동작 = 기본값).
//   MENTIONS — 본인이 @멘션된 답글에서만 알림(멘션은 mention.received 가 담당하므로
//              MENTIONS 구독자는 thread.replied fanout 에서 제외 — OFF 와 동일하게
//              "새 답글 알림 없음"이되, 멘션 시 mention.received 로는 도달한다).
//   OFF      — thread.replied fanout 전면 제외.
// 알림 fanout 은 notificationLevel != OFF(그리고 MENTIONS 제외)인 구독자만 대상.
enum ThreadNotificationLevel {
  ALL
  MENTIONS
  OFF
}

// S19 (FR-DM-12): DM 수신권한. EVERYONE = 누구나 DM 개시 가능,
// WORKSPACE_MEMBER = 공통 워크스페이스 멤버이거나 ACCEPTED 친구만 가능(default).
// FRIENDS_ONLY 는 Phase2 carryover — 이번 슬라이스에서는 enum 값으로도 선반영하지
// 않는다(거부만 한다). 기존 row 는 마이그레이션 DEFAULT 로 WORKSPACE_MEMBER 백필.
enum DmPrivacy {
  EVERYONE
  WORKSPACE_MEMBER
}

// S51 (D10 / FR-PS-07): 개인 저장함(Saved Messages)의 3탭 상태. Slack Later 3탭과
// 1:1 대응한다(IN_PROGRESS=진행 중, ARCHIVED=보관, COMPLETED=완료). S51 은 저장/해제/
// 목록/카운트만 구현하므로 신규 SavedMessage 행은 항상 IN_PROGRESS 로 생성되며, 탭 간
// 이동(PATCH 상태 변경)은 S52/FR-PS-08 의 carryover 다. enum 자체는 미리 3값을 모두
// 선언해 S52 가 마이그레이션 없이 PATCH 만 더하면 되게 한다.
enum SaveStatus {
  IN_PROGRESS
  ARCHIVED
  COMPLETED
}

enum NotificationChannel {
  TOAST
  BROWSER
  BOTH
  OFF
}

// S46 (D06 / ADR-6 / FR-MN-05/06/07/08): 알림 레벨 카노니컬 enum.
//   ALL      — 모든 메시지 알림.
//   MENTIONS — 멘션·키워드만(broad @everyone/@here 스킵, 직접 @username 통과). 기본값.
//   NOTHING  — 알림 없음(멘션 outbox 스킵 — 직접 @username 통과는 Inbox 기록 S47).
// 글로벌(UserSettings.notifTrigger) → 서버(ServerNotificationPref.level) → 채널
// (UserChannelMute.level, null=상속) 3계층이 모두 이 enum 을 공유한다(ADR-6).
// isMuted + muteUntil 은 level 과 독립한 3-필드 세트(뮤트는 NOTHING 과 별개).
enum NotifLevel {
  ALL
  MENTIONS
  NOTHING
}

// S54 (D11 / FR-RS-13): 메시지 읽음 처리 모드.
//   AUTO_FROM_POSITION   — 현재 스크롤 위치까지 자동 읽음(기본). Discord 기본 동작.
//   AUTO_FROM_LATEST     — 채널 진입 시 항상 최신까지 자동 읽음 처리.
//   MANUAL_FROM_LATEST   — 사용자가 명시적으로 "읽음 표시" 누를 때만 최신까지 처리.
// UserSettings.markAsReadMode 가 단일 출처. 행 없으면 AUTO_FROM_POSITION 폴백.
enum MarkAsReadMode {
  AUTO_FROM_POSITION
  AUTO_FROM_LATEST
  MANUAL_FROM_LATEST
}

// S46 (D06 / FR-MN-05): 사용자 글로벌 알림 설정. userId @unique — 사용자당 1행.
// 행이 없으면 기본 MENTIONS(backfill 불요 — resolve 시 행 부재를 MENTIONS 로 폴백).
// PRD NotificationPreference(글로벌) 카드에 대응하나, 본 프로젝트는 기존
// UserNotificationPreference(TOAST/BROWSER)와 충돌을 피하려 별도 UserSettings
// 테이블로 둔다. keywords 스캔은 S46 에서 컬럼 저장만(실 스캔은 BullMQ·S45 후속).
model UserSettings {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @unique @db.Uuid
  // 글로벌 알림 트리거. 기본값 MENTIONS(ADR-6).
  notifTrigger   NotifLevel     @default(MENTIONS)
  // 키워드 알림 — 최대 25개(서비스 레이어 enforce). S46 은 저장만.
  keywords       String[]       @default([])
  // 1회성 DND 종료 시각. null = 미설정. 주간 스케줄(dndSchedule)과 독립.
  dndUntil       DateTime?      @db.Timestamptz
  // 주간 DND 스케줄. shape: { days: [{ day, startMin, endMin }] } (me/dnd-schedule 정합).
  dndSchedule    Json?
  // S54 (D11 / FR-RS-13): 메시지 읽음 처리 모드. 기본 AUTO_FROM_POSITION.
  markAsReadMode MarkAsReadMode @default(AUTO_FROM_POSITION)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// S46 (D06 / FR-MN-06): 서버(워크스페이스) 단위 알림 오버라이드. (userId, workspaceId)
// 유니크 — 사용자·워크스페이스당 1행. 행이 없으면 글로벌(UserSettings) 상속.
// muteUntil null + isMuted=true = 영구 뮤트. suppressEveryone/suppressRoleMentions
// 은 S46 에서 컬럼 저장만(@everyone 게이트 연동은 S44 게이트와 묶음 후속).
model ServerNotificationPref {
  id                   String     @id @default(uuid()) @db.Uuid
  userId               String     @db.Uuid
  workspaceId          String     @db.Uuid
  level                NotifLevel @default(MENTIONS)
  isMuted              Boolean    @default(false)
  muteUntil            DateTime?  @db.Timestamptz
  suppressEveryone     Boolean    @default(false)
  suppressRoleMentions Boolean    @default(false)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // S46 fix-forward (HIGH): cron 만료 sweep 부분 인덱스 `(isMuted, muteUntil)
  // WHERE isMuted AND muteUntil IS NOT NULL` 는 raw SQL(20260602700000_s46_notif_levels)에
  // 둔다(Prisma @@index 는 partial WHERE 미지원 — UserChannelMute 와 동일).

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model UserNotificationPreference {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @db.Uuid
  workspaceId String?               @db.Uuid
  eventType   NotificationEventType
  channel     NotificationChannel
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@index([userId, workspaceId])
}

// task-045 iter3: channel/DM mute. mute > event-type pref 우선.
// mutedUntil null = indefinite mute. 미래 시각이면 그 시각까지.
// 만료된 row 는 cleanup job 없이 query 시 (mutedUntil > now) 필터로 제외.
// (userId, channelId) 가 unique — 한 채널은 1 행만.
model UserChannelMute {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @db.Uuid
  channelId  String      @db.Uuid
  mutedUntil DateTime?   @db.Timestamptz
  // S46 (D06 / FR-MN-07): 채널 단위 알림 레벨 오버라이드. null = 서버
  // (ServerNotificationPref) 상속(additive — 기존 row 는 NULL=상속이라 무회귀).
  // PRD ChannelNotificationPref 별도 테이블 대신 기존 UserChannelMute 에 level
  // 컬럼만 더해 S43 뮤트 UI·S22 사이드바·멘션 fanout 무교란을 노린 deviation 이다.
  level      NotifLevel?
  // S46 fix-forward (BLOCKER 3): 채널 뮤트 여부를 mutedUntil 과 분리한 명시 축.
  // 활성 뮤트 = isMuted && (mutedUntil null=영구 | mutedUntil>now). 이전에는
  // mutedUntil=null 이 "영구 뮤트"·"레벨전용 비뮤트(level 만 오버라이드)" 양쪽을
  // 뜻해 {level:ALL,isMuted:false} 가 채널 영구 차단으로 오작동했다(서버
  // ServerNotificationPref.isMuted 와 대칭). 마이그레이션이 기존 S43 뮤트 행을
  // isMuted=true 로 backfill 한다(무회귀).
  isMuted    Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  // cron 만료 sweep 부분 인덱스 `(isMuted, mutedUntil) WHERE isMuted AND mutedUntil
  // IS NOT NULL` 는 raw SQL(20260602700000_s46_notif_levels)로 둔다 — Prisma 의
  // @@index 가 partial WHERE 를 표현하지 못하므로 schema 에는 미선언(스키마-DB
  // 정합은 채널 partial-unique·S12 와 동일 패턴으로 raw SQL 측에서만 보장).

  @@unique([userId, channelId])
  @@index([channelId])
}

// S43 (FR-CH-15): 사용자별 채널 즐겨찾기. 사이드바 Favorites 섹션(최상단)에
// 표시되며 즐겨찾기 안에서의 순서는 fractional position(Decimal 20,10)으로
// 드래그 조정한다(채널/카테고리 position 과 동일 규약 — calcBetween 재사용).
// 개인 상태라 onDelete Cascade(user/channel 삭제 시 함께 정리). additive only —
// 신규 테이블이라 backfill 불요. 마이그레이션 20260602600000_s43_user_channel_favorite.
model UserChannelFavorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  channelId String   @db.Uuid
  position  Decimal  @db.Decimal(20, 10)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([userId, position])
}

// S51 (D10 / FR-PS-07): 개인 저장함. 철저히 개인 전용(Socket.IO 불요)이며 (userId,
// messageId) 유니크로 중복 저장을 방지한다(idempotent — 이미 있으면 현재 행 반환).
// status 는 3탭 필터링용, savedAt DESC 정렬과 함께 `(userId, status, savedAt DESC)`
// 복합 인덱스가 목록 조회를 커버한다. messageDeletedAt 은 원본 메시지가 soft-delete 될
// 때 비정규화로 기록해(조인 없이 '[삭제된 메시지]' 판단) read-path 를 단순화한다 —
// soft-delete 는 Cascade 가 처리하지 않으므로 messages.service.softDelete tx 가 직접
// updateMany 로 채운다. FK 는 둘 다 onDelete Cascade(원본 hard-delete/운영 purge 시
// 저장 행도 정리). additive 신규 테이블 — 기존 row 영향 없음(backfill 불요).
//
// ★스코프 최소화(S51): reminderAt/snoozedUntil/note 컬럼은 추가하지 않는다(리마인더는
// FR-PS-09~11/S53 의 BullMQ 의존 영역). PATCH 상태 이동도 S52/FR-PS-08 carryover 다.
// 마이그레이션 20260602800000_s51_pin_restrict_saved.
model SavedMessage {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String     @db.Uuid
  messageId        String     @db.Uuid
  status           SaveStatus @default(IN_PROGRESS)
  // 원본 메시지 soft-delete 시각(비정규화). null = 원본 살아 있음.
  messageDeletedAt DateTime?  @db.Timestamptz
  // S53 (D10 / FR-PS-09/10/11): 저장 리마인더 메타(전부 nullable).
  //   reminderAt      — 예약 발화 시각(UTC). null = 미설정.
  //   reminderFiredAt — 실제 발화 시각(중복 발화 방지 + overdue 판정). null = 미발화.
  //   snoozedUntil    — 스누즈("10분 후 다시") 재예약 시각.
  //   note            — 사용자 메모(≤500자).
  reminderAt       DateTime?  @db.Timestamptz
  reminderFiredAt  DateTime?  @db.Timestamptz
  snoozedUntil     DateTime?  @db.Timestamptz
  note             String?    @db.VarChar(500)
  savedAt          DateTime   @default(now()) @db.Timestamptz
  updatedAt        DateTime   @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  // ⚠️ S53 partial index "SavedMessage_reminderAt_idx" ON ("reminderAt")
  //   WHERE "reminderAt" IS NOT NULL AND "reminderFiredAt" IS NULL — Prisma 의
  //   @@index 는 partial WHERE 를 표현하지 못하므로 raw SQL(20260603100000) 로만
  //   정의한다. 여기에 full @@index([reminderAt]) 를 선언하면 introspection drift
  //   (다른 인덱스)를 만들므로 선언하지 않는다.

  @@unique([userId, messageId])
  @@index([userId, status, savedAt(sort: Desc)])
  @@index([messageId])
}

model User {
  id                          String             @id @db.Uuid
  email                       String             @unique
  username                    String             @unique
  passwordHash                String
  // S66 (D13 / FR-W05a/W05b): 이메일 인증 여부. 신규 가입자는 false 로 생성되며
  // GET /auth/verify-email 토큰 수락 시 true 로 전환된다. emailVerified=false 사용자는
  // 워크스페이스 진입(JOIN·ACCEPT·DOMAIN_JOIN) + 채널 메시지 전송이 서버 가드에서
  // 차단된다(403 EMAIL_NOT_VERIFIED). 기존 row 는 default false 로 backfill 되며(무회귀
  // — 인증 게이트만 추가), seed 사용자만 true 로 시드해 dev 차단을 피한다(additive +
  // reversible — 20260605000000_s66_email_verify).
  emailVerified               Boolean            @default(false)
  lastLoginAt                 DateTime?
  failedLoginAttempts         Int                @default(0)
  lockedUntil                 DateTime?
  // task-019-C: static DnD preference consulted by the WS gateway at
  // connect time. "auto" keeps 005 semantics; "dnd" shows as Do Not
  // Disturb until the user flips it back. Runtime presence state (in
  // Redis via PresenceService) still goes to `offline` on disconnect.
  presencePreference          PresencePreference @default(auto)
  // S27 (FR-P10): 마지막 접속 시각. OFFLINE 확정(finalizeOffline) + DND 전환에서
  // 갱신, INVISIBLE 전환에서는 미갱신(잠적 시각 누출 방지). nullable — 기존 row 는
  // NULL(접속 기록 없음). 멤버 목록 offline 그룹의 "마지막 접속" 표기에만 쓰이는
  // 파생 표시값이며 runtime presence 의 단일 출처는 Redis 다.
  lastSeenAt                  DateTime?          @db.Timestamptz
  // task-045 iter4: Discord-parity custom status text. null = unset.
  // 100 chars cap (Discord 의 128 보다 보수적).
  customStatus                String?            @db.VarChar(100)
  // S28 (FR-P04): 구조화 커스텀 상태. text 는 위 customStatus 가 보유하고,
  // emoji / expiresAt 를 분리 컬럼으로 더한다(기존 read 경로 무회귀).
  //   customStatusEmoji     — 이모지 또는 :shortcode: (null = 없음)
  //   customStatusExpiresAt — 만료 시각(UTC). null = 무기한. FR-P17 만료는
  //                           read-time lazy clear 로 처리(expiresAt<now 면 빈 상태).
  customStatusEmoji           String?            @db.VarChar(64)
  customStatusExpiresAt       DateTime?          @db.Timestamptz
  // S28 (FR-P04): 프리셋 계산 기준 IANA timezone(예: "Asia/Seoul"). null =
  // 미설정 → 클라 브라우저 tz fallback. 프리셋은 서버가 이 tz 로 계산해 UTC 저장.
  timezone                    String?            @db.VarChar(64)
  // task-046 iter4 (K1): per-day weekly DnD schedule.
