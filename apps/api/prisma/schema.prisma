// Prisma schema for qufox (Phase 0 bootstrap)
// Tables: User, Workspace, WorkspaceMember, Channel, Message, Invite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  TEXT
  VOICE
  ANNOUNCEMENT
  FORUM
  DIRECT
}

// S01 (ADR-2): Message author classification. Default USER keeps every
// existing row valid without a backfill (DB default fills NULLs at add
// time). BOT / SYSTEM land in later slices (webhooks / system messages).
enum AuthorType {
  USER
  BOT
  SYSTEM
}

// S04 (ADR-2 / FR-MSG-19 / FR-RC10) — MessageType 단일 카노니컬 정의.
// 값 집합은 packages/shared-types/src/message-type.ts 와 1:1 동기화됩니다.
// SYSTEM_* 는 authorType=SYSTEM, grouped=false 강제, 편집·삭제 UI 미표시.
enum MessageType {
  DEFAULT
  SYSTEM_MEMBER_JOINED
  SYSTEM_MEMBER_LEFT
  SYSTEM_MEMBER_BANNED
  SYSTEM_PIN
  SYSTEM_CHANNEL_RENAME
  SYSTEM_CHANNEL_TOPIC_CHANGED
  SYSTEM_CHANNEL_ARCHIVED
  SYSTEM_THREAD_BROADCAST
}

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String
  aggregateId   String    @db.Uuid
  eventType     String
  payload       Json
  occurredAt    DateTime  @default(now())
  dispatchedAt  DateTime?
  attempts      Int       @default(0)
  lastError     String?

  @@index([dispatchedAt, occurredAt])
  @@index([aggregateType, aggregateId])
}

enum PresencePreference {
  auto
  dnd
}

enum NotificationEventType {
  MENTION
  REPLY
  REACTION
  DIRECT
  FRIEND_REQUEST
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum NotificationChannel {
  TOAST
  BROWSER
  BOTH
  OFF
}

model UserNotificationPreference {
  id          String                 @id @default(uuid()) @db.Uuid
  userId      String                 @db.Uuid
  workspaceId String?                @db.Uuid
  eventType   NotificationEventType
  channel     NotificationChannel
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, eventType])
  @@index([userId, workspaceId])
}

// task-045 iter3: channel/DM mute. mute > event-type pref 우선.
// mutedUntil null = indefinite mute. 미래 시각이면 그 시각까지.
// 만료된 row 는 cleanup job 없이 query 시 (mutedUntil > now) 필터로 제외.
// (userId, channelId) 가 unique — 한 채널은 1 행만.
model UserChannelMute {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  channelId   String    @db.Uuid
  mutedUntil  DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId])
}

model User {
  id                  String             @id @db.Uuid
  email               String             @unique
  username            String             @unique
  passwordHash        String
  lastLoginAt         DateTime?
  failedLoginAttempts Int                @default(0)
  lockedUntil         DateTime?
  // task-019-C: static DnD preference consulted by the WS gateway at
  // connect time. "auto" keeps 005 semantics; "dnd" shows as Do Not
  // Disturb until the user flips it back. Runtime presence state (in
  // Redis via PresenceService) still goes to `offline` on disconnect.
  presencePreference  PresencePreference @default(auto)
  // task-045 iter4: Discord-parity custom status text. null = unset.
  // 100 chars cap (Discord 의 128 보다 보수적). emoji prefix 는
  // follow-up — 현재는 plain text 만.
  customStatus        String?            @db.VarChar(100)
  // task-046 iter4 (K1): per-day weekly DnD schedule.
  // shape: { days: [{ day: 0..6 (Sun..Sat), startMin: 0..1439, endMin: 0..1439 }] }
  // start>end 인 entry 는 overnight (23:00 → 07:00).
  dndSchedule         Json?
  // task-046 iter4 (K4): 첫 알림 onboarding 노출 여부.
  notificationOnboardingShown Boolean    @default(false)
  // task-046 iter5 (M1): Discord-parity profile bio. markdown 허용,
  // 500 chars cap (app layer). links 는 markdown URL 로 표현 (별도
  // column 없음).
  bio                 String?
  // task-047 iter3 (M2): Discord-parity profile 외부 링크.
  // shape: Array<{ url: string, label?: string }>, cap 3 (app layer).
  // null = no links.
  links               Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  messages        Message[]
  invitesCreated  Invite[]          @relation("InviteCreator")
  refreshTokens   RefreshToken[]
  attachments     Attachment[]
  reactions       MessageReaction[]
  feedback        Feedback[]
  notificationPreferences UserNotificationPreference[]
  activityReadStates      UserActivityReadState[]
  channelMutes            UserChannelMute[]
  friendshipsRequested    Friendship[]               @relation("FriendshipRequester")
  friendshipsReceived     Friendship[]               @relation("FriendshipAddressee")
  customEmojis            CustomEmoji[]              @relation("CustomEmojiCreator")
  threadSubscriptions     ThreadSubscription[]
}

// task-046 iter6 (N1, N2, N3): thread follow / 구독.
// follow 상태는 mention dispatcher 가 thread reply 알림 분기에 사용.
model ThreadSubscription {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  threadParentId  String   @db.Uuid
  createdAt       DateTime @default(now()) @db.Timestamptz(6)

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadParent   Message @relation("MessageThreadFollowers", fields: [threadParentId], references: [id], onDelete: Cascade)

  @@unique([userId, threadParentId])
  @@index([threadParentId])
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  familyId   String    @db.Uuid
  parentId   String?   @db.Uuid
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

enum WorkspaceVisibility {
  PUBLIC
  PRIVATE
}

enum WorkspaceCategory {
  PROGRAMMING
  GAMING
  MUSIC
  ENTERTAINMENT
  SCIENCE
  TECH
  EDUCATION
  OTHER
}

model Workspace {
  id          String              @id @db.Uuid
  name        String
  slug        String              @unique
  description String?
  iconUrl     String?
  ownerId     String              @db.Uuid
  // task-030: visibility + category drive /workspaces/discover. Existing
  // rows backfill to PRIVATE (reversible): discovery page shows zero
  // pre-existing workspaces until owners opt in via Settings.
  visibility  WorkspaceVisibility @default(PRIVATE)
  category    WorkspaceCategory?
  deletedAt   DateTime?
  deleteAt    DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  owner      User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members    WorkspaceMember[]
  channels   Channel[]
  categories Category[]
  invites    Invite[]
  feedback   Feedback[]
  notificationPreferences UserNotificationPreference[]
  customEmojis CustomEmoji[]

  @@index([ownerId])
  @@index([deletedAt])
  @@index([visibility, category])
}

model WorkspaceMember {
  workspaceId String        @db.Uuid
  userId      String        @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  position    Decimal   @db.Decimal(20, 10)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  channels    Channel[]

  @@unique([workspaceId, name])
  @@index([workspaceId, position])
}

model Channel {
  id          String      @id @default(uuid()) @db.Uuid
  // task-034-A: workspaceId is nullable — DIRECT channels live in the
  // global DM scope (no parent workspace). The DB CHECK in the
  // migration enforces "(type='DIRECT') OR (workspaceId IS NOT NULL)"
  // so non-DIRECT rows always have a workspace. The OR is intentionally
  // NOT XOR: 027-era DIRECT rows with a host workspaceId stay legal
  // for back-compat.
  // A partial UNIQUE index (task-034 reviewer HIGH fix) enforces
  // (name) uniqueness in the null-workspace DIRECT subset — postgres
  // treats NULL as distinct in standard unique indexes, so the plain
  // @@unique([workspaceId, name]) below doesn't close the
  // createOrGet race on its own.
  // Pre-migration prod audit: 0 DIRECT rows, so no backfill needed.
  workspaceId String?     @db.Uuid
  categoryId  String?     @db.Uuid
  name        String
  type        ChannelType @default(TEXT)
  topic       String?
  position    Decimal     @db.Decimal(20, 10)
  isPrivate   Boolean     @default(false)
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace?                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category    Category?                   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages    Message[]
  attachments Attachment[]
  overrides   ChannelPermissionOverride[]
  mutes       UserChannelMute[]

  // S12 (FR-CH-03): channel-name uniqueness within a workspace is enforced by a
  // PARTIAL unique index `(workspaceId, name) WHERE "deletedAt" IS NULL`
  // (raw SQL in 20260531180000_s12_channel_name_partial_unique — Prisma's
  // @@unique can't express the partial WHERE). A soft-deleted row no longer
  // occupies its name, so the name is immediately reusable. The full-table
  // @@unique([workspaceId, name]) was dropped in that migration.
  @@index([workspaceId, categoryId, position])
  @@index([workspaceId, deletedAt])
}

// Task-012-D: per-channel permission override. principalType = 'USER'
// (principalId = User.id UUID) or 'ROLE' (principalId = WorkspaceRole
// literal: OWNER/ADMIN/MEMBER). Masks are bitfields per
// apps/api/src/auth/permissions.ts; DENY > ALLOW.
model ChannelPermissionOverride {
  id            String   @id @default(uuid()) @db.Uuid
  channelId     String   @db.Uuid
  principalType String   @db.VarChar(8)
  principalId   String   @db.VarChar(64)
  allowMask     Int      @default(0)
  denyMask      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, principalType, principalId])
  @@index([channelId])
}

model Message {
  id             String    @id @default(uuid()) @db.Uuid
  channelId      String    @db.Uuid
  authorId       String    @db.Uuid
  content        String
  contentPlain   String
  mentions       Json      @default("{\"users\":[],\"channels\":[],\"everyone\":false}")
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // client-generated uuid for POST retry dedupe — null when no header was sent.
  // S03 (ADR-2 / FR-MSG-05): uniqueness is USER-scoped via a PARTIAL unique
  // index `(authorId, idempotencyKey) WHERE idempotencyKey IS NOT NULL`
  // created in raw SQL (schema-level `@@unique` would index every NULL row
  // too, and Prisma can't express the partial WHERE). User A's key reused by
  // user B yields a new row. The legacy channel-scoped index is retained
  // through the expand window and dropped in the same migration's down.sql.
  // `nonce` (clientNonce) lives separately as an optimistic-UI echo only;
  // we store it on send so reconnect-resend dedupe is observable.
  idempotencyKey String?   @db.Uuid
  // S03 (FR-MSG-04): clientNonce echo. UUID v4 the client sends in the POST
  // body; mirrored on the message:created WS event for optimistic swap.
  // Additive nullable — system/legacy rows are NULL. NOT a dedupe key
  // (that is idempotencyKey); persisted for observability + reconnect flows.
  nonce          String?   @db.Uuid
  // task-014-B: single-level threads. Self-FK; ON DELETE SET NULL means
  // a hard-deleted root turns its replies into pseudo-roots (purge
  // worker is the only path that hard-deletes). Soft delete leaves the
  // row intact and hides the content at the DTO layer. Single-level
  // depth is enforced at the service — parent-of-parent must be NULL.
  parentMessageId String?  @db.Uuid

  // task-015-B: Postgres-generated tsvector column for FTS. Marked
  // `Unsupported` because Prisma 5.22 doesn't model tsvector natively;
  // the column is populated by the DB via GENERATED ALWAYS AS, so we
  // never write to it. SELECT paths that need FTS use $queryRaw.
  search_tsv  Unsupported("tsvector")?

  // task-044-iter2: pinned messages. NULL = 미고정. Discord-parity cap
  // 50/channel enforced at service layer. Author 가 일반 MEMBER 라도
  // OWNER/ADMIN 이 pin 할 수 있어 pinnedBy 는 author 와 다를 수 있다.
  pinnedAt   DateTime? @db.Timestamptz
  pinnedBy   String?   @db.Uuid

  // ── S01 (ADR-2 카노니컬 additive 토대) ────────────────────────────────────
  // expand-contract: 이번 슬라이스는 ADDITIVE 만. 신규 컬럼은 전부 nullable
  // 또는 default 동반이라 기존 row 가 안전하다. 기존 `content` / `contentPlain`
  // 컬럼은 그대로 유지(병행) — cuid2 PK 전환과 raw/ast 백필은 별도 트랙.
  //
  // contentRaw : 원본 mrkdwn (편집 diff용). 기존 row 는 NULL — 서비스
  //   레이어가 읽을 때 `content` 로 폴백한다. 신규 write 경로가 채운다.
  contentRaw  String?   @db.Text
  // contentAst : 파싱된 rich_text AST(JSONB). 구조 계약은
  //   packages/shared-types RichTextRootSchema. 기존 row 는 NULL.
  contentAst  Json?
  // contentPlainV2 : ADR-2 contentPlain 의 신규 nullable 슬롯. 기존 NOT NULL
  //   `contentPlain` 컬럼과 병행한다(기존 컬럼 타입/제약 변경 금지 규칙).
  //   백필 완료 후 contract 단계에서 단일화한다.
  contentPlainV2 String? @db.Text
  // version : 낙관적 잠금 버전. default 0 이라 기존 row 는 자동 0.
  version     Int       @default(0)
  // seq : 채널 단위 단조 증가(Redis INCR seq:{channelId}) 발급값 영속 사본.
  //   힌트 용도이며 렌더 정렬 기준은 아님(D17). 기존 row 는 NULL.
  seq         BigInt?
  // authorType : USER | BOT | SYSTEM. default USER 라 기존 row 안전(ADR-2).
  authorType  AuthorType @default(USER)
  // S04 (ADR-2 / FR-MSG-19): 메시지 타입. default DEFAULT 라 기존 row 안전
  // (additive + reversible). SYSTEM_* 는 시스템 행 렌더 + grouped=false 강제.
  type        MessageType @default(DEFAULT)

  channel     Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author      User              @relation(fields: [authorId], references: [id])
  attachments Attachment[]
  reactions   MessageReaction[]
  parent      Message?          @relation("MessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies     Message[]         @relation("MessageReplies")
  threadFollowers ThreadSubscription[] @relation("MessageThreadFollowers")
  // S05 (FR-MSG-06): 편집 이력 스냅샷(ring buffer cap 10). 메시지 hard
  // delete 시 Cascade 로 함께 정리됩니다.
  editHistory MessageEditHistory[] @relation("MessageEditHistory")

  // pagination primary path — matches ORDER BY createdAt DESC, id DESC with
  // row-value comparison WHERE (createdAt, id) < ($1, $2).
  @@index([channelId, createdAt, id])
  // S01 (ADR-2 / FR-RT-18): 단순 ID 조회 보조 + cuid2 커서(id DESC) 경로.
  @@index([channelId, id])
  // includeDeleted=false default path (soft-delete filter).
  @@index([channelId, deletedAt, createdAt])
  @@index([authorId])
  // thread replies list — ORDER BY createdAt ASC for the ThreadPanel.
  // Partial index `(channelId, createdAt DESC) WHERE parentMessageId IS NULL`
  // + the replies index `(parentMessageId, createdAt ASC)` are defined in
  // the raw-SQL migration (Prisma's @@index doesn't support partial WHERE).
  @@index([parentMessageId, createdAt])
  // task-044-iter2: pinned list — 채널별 pinned ORDER BY pinnedAt DESC.
  // Partial WHERE pinnedAt IS NOT NULL 은 raw-SQL migration 으로 보강합니다
  // (Prisma @@index 가 partial 미지원).
  @@index([channelId, pinnedAt])
}

// Task-013-B: per-message reactions. `emoji` is the literal unicode
// string as picked; VARCHAR(64) gives room for ZWJ sequences. API
// enforces ≤4 codepoint cap on top. (messageId, userId, emoji) is
// unique so POST is naturally idempotent — see ReactionsService.
model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String   @db.VarChar(64)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId, emoji])
}

// S05 (FR-MSG-06 / FR-RC16): 메시지 편집 이력 스냅샷.
// 편집(PATCH) 시 직전 본문(contentRaw/contentAst/contentPlain)을 한 행으로
// 적재합니다. `version` 은 스냅샷 당시(편집 전) 메시지 version 입니다. 채널당
// 메시지별 ring buffer cap 은 서비스 레이어에서 10 으로 enforce 하며, 11번째
// 편집 시 가장 오래된 version 1개를 DELETE 합니다(DB 제약 아님 — 운영 유연성).
// additive only — 신규 테이블이라 기존 row 영향 없음. seed 결정성 무관.
model MessageEditHistory {
  id          String   @id @default(uuid()) @db.Uuid
  messageId   String   @db.Uuid
  // 스냅샷 당시(편집 전) 메시지 version.
  version     Int
  // 편집 전 본문 스냅샷. contentRaw 는 legacy row 에서 NULL 가능.
  contentRaw  String?  @db.Text
  contentAst  Json?
  contentPlain String  @db.Text
  // 스냅샷 생성(=해당 편집 발생) 시각.
  editedAt    DateTime @db.Timestamptz
  createdAt   DateTime @default(now())

  message Message @relation("MessageEditHistory", fields: [messageId], references: [id], onDelete: Cascade)

  // ring buffer 정렬(version asc/desc) + (messageId, version) 조회 경로.
  @@index([messageId, version])
}

enum AttachmentKind {
  IMAGE
  VIDEO
  FILE
}

model Attachment {
  id                 String         @id @default(uuid()) @db.Uuid
  channelId          String         @db.Uuid
  messageId          String?        @db.Uuid
  uploaderId         String         @db.Uuid
  clientAttachmentId String?        @db.Uuid
  kind               AttachmentKind
  mime               String         @db.VarChar(127)
  sizeBytes          BigInt
  storageKey         String
  originalName       String
  finalizedAt        DateTime?
  createdAt          DateTime       @default(now())

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploaderId], references: [id])

  // Indexes are created in the migration as partial indexes (Prisma
  // has no @@index-with-WHERE syntax). See
  // 20260421000000_add_attachment_table/migration.sql.
}

// task-037-D: workspace-scoped custom emoji pack. MinIO-backed (see
// scripts/setup/init-minio.sh for the bucket setup). cap = 100
// emojis per workspace is enforced at the API layer.
model CustomEmoji {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  name        String   @db.VarChar(32)
  createdBy   String   @db.Uuid
  storageKey  String
  mime        String   @db.VarChar(127)
  sizeBytes   BigInt
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User      @relation("CustomEmojiCreator", fields: [createdBy], references: [id])

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model UserChannelReadState {
  userId          String   @db.Uuid
  channelId       String   @db.Uuid
  // Points at an OutboxEvent.id — the last event this user has fully
  // processed client-side. Drives reconnect replay ("replay everything after
  // X"). PRESERVED in S11 — reconnect replay still keys off this column.
  lastReadEventId String   @db.Uuid
  // S11 (FR-RT-14/19): legacy createdAt-only read threshold. PRESERVED so
  // the mention-inbox proxy (me-mentions.service) keeps working. Channel
  // unread now drives off the (createdAt, id) tuple below.
  lastReadAt      DateTime @default(now())
  // S11 (FR-RT-19): monotonic read cursor as a sortable (createdAt, id)
  // tuple. Message.id is a RANDOM uuid (no S00 sortable-id foundation), so
  // a bare `id >` comparison is order-meaningless — we instead compare the
  // (createdAt, id) tuple, matching the canonical message sort the cursor
  // pagination already uses (messages.service). Both columns are nullable:
  // existing rows + freshly-joined channels back-fill to NULL ⇒ "every
  // message is unread", which is the intended UX.
  lastReadMessageId        String?   @db.Uuid
  lastReadMessageCreatedAt DateTime? @db.Timestamptz
  updatedAt       DateTime @updatedAt

  @@id([userId, channelId])
  @@index([channelId])
}

// task-032: Friendship — single row per directed pair. ACCEPTED +
// BLOCKED collapse to one row (vs two symmetric ones) to keep unique
// semantics tight: there can never be two ACCEPTED rows for the same
// pair. Lookup must check both (requesterId, addresseeId) and
// (addresseeId, requesterId).
model Friendship {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @db.Uuid
  addresseeId String           @db.Uuid
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// task-026: Activity inbox read state. Keyed per-user + per-activityKey
// (synthesised from the underlying messages / reactions record), so a
// user can mark a specific mention / reply / reaction row as read
// without affecting the channel-level read state.
model UserActivityReadState {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  activityKey String
  readAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityKey])
  @@index([userId, readAt(sort: Desc)])
}

model Invite {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  code        String    @unique
  createdById String    @db.Uuid
  expiresAt   DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([expiresAt])
}

// task-016-C-3: user-submitted beta feedback. Prisma models the enum
// + table; the DB-layer `char_length <= 2000` CHECK constraint lives
// in the migration SQL (Prisma doesn't emit CHECK constraints).
enum FeedbackCategory {
  BUG
  FEATURE
  OTHER
}

model Feedback {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String?          @db.Uuid
  workspaceId String?          @db.Uuid
  category    FeedbackCategory
  content     String           @db.Text
  page        String?
  userAgent   String?
  createdAt   DateTime         @default(now())

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}
