// Prisma schema for qufox (Phase 0 bootstrap)
// Tables: User, Workspace, WorkspaceMember, Channel, Message, Invite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  TEXT
  VOICE
  ANNOUNCEMENT
}

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String
  aggregateId   String    @db.Uuid
  eventType     String
  payload       Json
  occurredAt    DateTime  @default(now())
  dispatchedAt  DateTime?
  attempts      Int       @default(0)
  lastError     String?

  @@index([dispatchedAt, occurredAt])
  @@index([aggregateType, aggregateId])
}

model User {
  id                  String    @id @db.Uuid
  email               String    @unique
  username            String    @unique
  passwordHash        String
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  messages        Message[]
  invitesCreated  Invite[]          @relation("InviteCreator")
  refreshTokens   RefreshToken[]
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  familyId   String    @db.Uuid
  parentId   String?   @db.Uuid
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model Workspace {
  id          String    @id @db.Uuid
  name        String
  slug        String    @unique
  description String?
  iconUrl     String?
  ownerId     String    @db.Uuid
  deletedAt   DateTime?
  deleteAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner      User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members    WorkspaceMember[]
  channels   Channel[]
  categories Category[]
  invites    Invite[]

  @@index([ownerId])
  @@index([deletedAt])
}

model WorkspaceMember {
  workspaceId String        @db.Uuid
  userId      String        @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  position    Decimal   @db.Decimal(20, 10)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  channels    Channel[]

  @@unique([workspaceId, name])
  @@index([workspaceId, position])
}

model Channel {
  id          String      @id @default(uuid()) @db.Uuid
  workspaceId String      @db.Uuid
  categoryId  String?     @db.Uuid
  name        String
  type        ChannelType @default(TEXT)
  topic       String?
  position    Decimal     @db.Decimal(20, 10)
  isPrivate   Boolean     @default(false)
  archivedAt  DateTime?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages  Message[]

  @@unique([workspaceId, name])
  @@index([workspaceId, categoryId, position])
  @@index([workspaceId, deletedAt])
}

model Message {
  id        String    @id @db.Uuid
  channelId String    @db.Uuid
  authorId  String    @db.Uuid
  content   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([channelId, createdAt])
}

model Invite {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  code        String    @unique
  createdById String    @db.Uuid
  expiresAt   DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([expiresAt])
}
