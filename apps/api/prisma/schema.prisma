// task-046 iter6 (N1, N2, N3): thread follow / 구독.
// follow 상태는 mention dispatcher 가 thread reply 알림 분기에 사용.
model ThreadSubscription {
  id                String                  @id @default(uuid()) @db.Uuid
  userId            String                  @db.Uuid
  threadParentId    String                  @db.Uuid
  // S38 (D04 / FR-TH-08): 알림 레벨. default ALL 이라 기존 row 안전(additive +
  // reversible — 마이그레이션 20260602300000_s38_thread_notif_level_lock). 자동
  // 구독(send tx)은 새 행을 ALL 로 만들고, 사용자가 벨 드롭다운에서 PATCH 로
  // MENTIONS/OFF 로 낮춘다. fanout(buildThreadReplyPayload)이 OFF/MENTIONS 를
  // thread.replied 수신자에서 제외한다.
  notificationLevel ThreadNotificationLevel @default(ALL)
  createdAt         DateTime                @default(now()) @db.Timestamptz(6)

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  threadParent Message @relation("MessageThreadFollowers", fields: [threadParentId], references: [id], onDelete: Cascade)

  @@unique([userId, threadParentId])
  @@index([threadParentId])
  // S38 (FR-TH-08): fanout 필터(level != OFF) 가 userId 스코프로 구독을 스캔할 때
  // 쓰는 보조 인덱스. Threads 탭 목록도 userId 선두로 조회한다.
  @@index([userId, notificationLevel])
}

// S36 (D04·D09 / FR-RS-12 / FR-TH-11/12/18): 스레드 단위 읽음 커서.
//
// 채널 미읽(UserChannelReadState)과 동일한 (createdAt, id) 튜플 커서 패턴을
// 그대로 따른다(S11 정합). Message.id 가 랜덤 uuid(비정렬)라 `id >` 단독
// 비교가 메시지 순서와 무관하므로, 미읽 판정은 (createdAt, id) 튜플로 한다.
//
// 설계 결정(S36 — 옵션 B "unread = 계산"):
//   - **튜플 커서만** 저장한다(lastReadMessageId + lastReadMessageCreatedAt).
//     denormalized `unreadCount` 컬럼은 두지 않는다 — 미읽 수는 조회 시 SQL
//     COUNT 로 계산해 drift 를 원천 차단한다(S11 채널-unread 와 동일 철학).
//     denormalized unreadCount 컬럼 + Threads 탭(FR-TH-09/10)은 S38 carryover.
//   - PRD 데이터 모델 카드는 cuid2 PK + unreadCount 컬럼을 그렸으나, 본
//     프로젝트의 Message/UserChannelReadState 가 모두 uuid PK + 튜플 커서라
//     실제 코드 정합을 위해 uuid PK + 튜플-커서-only 로 둔다(S11 패턴 단일화).
//
// 키: (userId, parentMessageId) 유니크. parentMessageId 는 스레드 루트 메시지
// id 다. 행이 없거나 커서가 NULL 이면 "전체 답글 미읽"(신규 스레드 UX 일치).
// additive only — 신규 테이블이라 기존 row 영향 없음. backfill 불필요.
model ThreadReadState {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String    @db.Uuid
  parentMessageId          String    @db.Uuid
  // 마지막으로 읽은 답글의 (createdAt, id) 튜플 커서. 둘 다 nullable —
  // 신규 스레드(ACK 전)는 NULL ⇒ 전체 답글 미읽.
  lastReadMessageId        String?   @db.Uuid
  lastReadMessageCreatedAt DateTime? @db.Timestamptz
  updatedAt                DateTime  @updatedAt

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // parentMessageId = 스레드 루트. 루트 hard delete(운영 purge) 시 Cascade.
  parentMessage Message @relation("MessageThreadReadStates", fields: [parentMessageId], references: [id], onDelete: Cascade)

  @@unique([userId, parentMessageId])
  @@index([parentMessageId])
  // Threads 탭(S38)의 "내 스레드 최근순" 조회용 — userId 스코프 updatedAt DESC.
  @@index([userId, updatedAt(sort: Desc)])
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  familyId   String    @db.Uuid
  parentId   String?   @db.Uuid
  userAgent  String?
  ip         String?
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

// S66 (D13 / FR-W05b): 이메일 인증 토큰. signup 시 1행 생성 + ConsoleMailSender 로
// verifyUrl 출력하고, GET /auth/verify-email?token= 수락 시 usedAt 을 찍어 재사용을
// 막는다. token 은 추측 불가한 uuid v4 이며 token @unique 인덱스로 O(1) 조회한다.
// expiresAt(발급+24h) 경과 시 410, usedAt 존재 시 400 으로 거부한다. additive 신규
// 테이블이라 기존 row 영향 없음(backfill 불요). onDelete Cascade — 계정 하드삭제 시
// 토큰 행도 함께 정리된다. 재발송 rate-limit(60s 쿨다운·1일 5회)은 토큰 행이 아닌
// Redis 키(email_verify_resend:{userId} · email_verify_daily:{userId})로 집행한다.
model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique @db.Uuid
  expiresAt DateTime  @db.Timestamptz(6)
  usedAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum WorkspaceVisibility {
  PUBLIC
  PRIVATE
}

// S65 (D13 / FR-W01): 워크스페이스 가입 방식. visibility(discover 노출 여부)와는
// 직교한다 — visibility 는 "찾기 페이지에 보이는가", joinMode 는 "어떻게 들어오는가".
//   PRIVATE — 초대 전용(기본). PUBLIC — 즉시 가입(joinPublic). APPLY — 신청 후 승인
// (신청 플로우 FR-W06 은 S66+ carryover; S65 는 생성 시 모드 설정만 한다).
enum WorkspaceJoinMode {
  PRIVATE
  PUBLIC
  APPLY
}

// S70 (D13 / FR-W06): 가입 신청(APPLY 모드) 상태 머신.
//   PENDING   — 제출 후 검토 대기(기본값). 이 상태에서만 신청자가 취소(WITHDRAWN)할 수 있다.
//   APPROVED  — ADMIN+ 승인. 같은 트랜잭션에서 WorkspaceMember 가 생성된다.
//   REJECTED  — MODERATOR+ 거절(reviewNote 선택). 24h cooldown 후 재신청 가능.
//   INTERVIEW — ADMIN+ 인터뷰 전환. 신청자와 1:1 DM(interviewChannelId)이 자동 생성되고,
//               인터뷰 후 동일 신청서를 다시 approve/reject 한다(상태 행 UPDATE).
//   WITHDRAWN — 신청자 본인 취소(PENDING 에서만). 재신청 허용.
// 신규 enum 이라 기존 row 영향 없음(reversible — down 에서 테이블·타입 DROP).
enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  INTERVIEW
  WITHDRAWN
}

// S71 (D13 / FR-W08): 관심사 질문 유형.
//   SINGLE     — 단일 선택(라디오). 선택지 1개의 channelIds/roleId 적용.
//   MULTI      — 다중 선택(체크박스). 선택한 모든 선택지의 channelIds/roleId 적용.
//   SHORT_TEXT — 자유 입력. 선택지 없음 · 답변은 WorkspaceMember.onboardingAnswers 에 저장.
// 신규 enum 이라 기존 row 영향 없음(reversible — down 에서 타입 DROP).
enum QuestionType {
  SINGLE
  MULTI
  SHORT_TEXT
}

enum WorkspaceCategory {
  PROGRAMMING
  GAMING
  MUSIC
  ENTERTAINMENT
  SCIENCE
  TECH
  EDUCATION
  OTHER
}

model Workspace {
  id               String              @id @db.Uuid
  name             String
  slug             String              @unique
  description      String?
  iconUrl          String?
  ownerId          String              @db.Uuid
  // task-030: visibility + category drive /workspaces/discover. Existing
  // rows backfill to PRIVATE (reversible): discovery page shows zero
  // pre-existing workspaces until owners opt in via Settings.
  visibility       WorkspaceVisibility @default(PRIVATE)
  category         WorkspaceCategory?
  // S65 (D13 / FR-W01): 가입 방식. visibility 와 직교(가입 vs 노출). 기존 row 는
  // PRIVATE 로 backfill 되어 discover/joinPublic 무회귀.
  joinMode         WorkspaceJoinMode   @default(PRIVATE)
  // S65 (D13 / FR-W01): 이메일 도메인 화이트리스트. 빈 배열 = 제한 없음. 신청/초대
  // 게이트(FR-W06 등 후속)가 참조할 예정이며, S65 는 생성 시 저장만 한다.
  emailDomains     String[]            @default([])
  // S65 (D13 / FR-W19): 기본 채널(가입자 랜딩). 생성 시 #general 로 세팅된다. 대상
  // 채널 hard-delete 시 ON DELETE SET NULL(아래 FK)로 끊긴다.
  defaultChannelId String?             @db.Uuid
  deletedAt        DateTime?
  deleteAt         DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  owner                   User                         @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  // S65 (D13 / FR-W19): 기본 채널 FK. SetNull — 채널 삭제 시 workspace 행은 유지하고
  // defaultChannelId 만 NULL 로 끊는다. NoAction 로 Channel.workspace 관계와의
  // 다중 캐스케이드 경로 충돌을 피한다(아래 references 명시 relation 이름으로 분리).
  defaultChannel          Channel?                     @relation("WorkspaceDefaultChannel", fields: [defaultChannelId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  members                 WorkspaceMember[]
  channels                Channel[]
  categories              Category[]
  invites                 Invite[]
  // S68 (D13 / FR-W04·W18): 이메일 보류 초대들. onDelete Cascade(워크스페이스 삭제 시 정리).
  pendingInvites          WorkspacePendingInvite[]
  feedback                Feedback[]
  notificationPreferences UserNotificationPreference[]
  // S46 (D06 / FR-MN-06): 이 워크스페이스의 서버별 알림 오버라이드. onDelete Cascade.
  serverNotificationPrefs ServerNotificationPref[]
  customEmojis            CustomEmoji[]
  // S42 (FR-PK04): 워크스페이스 이모지 설정(1:1, 퀵반응 기본값 + canMemberUpload).
  emojiConfig             WorkspaceEmojiConfig?
  // S55 (D11 / FR-AM-20): 워크스페이스 첨부 정책(1:1, 최대 크기 + 차단 확장자).
  setting                 WorkspaceSetting?
  // S61 (D12 / FR-RM01): 워크스페이스의 역할 집합(시스템 5역할 + 커스텀). onDelete Cascade.
  roles                   Role[]
  // S62 (D12 / FR-RM17): 모더레이션/관리 감사 로그(append-only). onDelete Cascade.
  auditLogs               AuditLog[]
  // S63 (D12 / FR-RM06): 워크스페이스 영구 차단 목록. onDelete Cascade.
  bannedMembers           BannedMember[]
  // S64 (D12 / FR-RM11): 메시지 신고 큐. onDelete Cascade.
  moderationReports       ModerationReport[]
  // S70 (D13 / FR-W06): 가입 신청(APPLY 모드) 큐. onDelete Cascade.
  applications            WorkspaceMemberApplication[]
  // S71 (D13 / FR-W07·W08·W09): 워크스페이스 온보딩 카탈로그. 모두 onDelete Cascade.
  rules                   WorkspaceRule[]
  onboardingQuestions     OnboardingQuestion[]
  welcome                 WorkspaceWelcome?
  // S74 (D14 / FR-PS-06): 이 워크스페이스의 멤버별 프로필 오버라이드들. onDelete Cascade.
  memberProfiles          WorkspaceMemberProfile[]

  @@index([ownerId])
  @@index([deletedAt])
  @@index([visibility, category])
}

// S74 (D14 / FR-PS-06 · Fork2 Option B): 워크스페이스별 프로필 오버라이드.
//
// 멤버가 특정 워크스페이스에서만 쓰는 닉네임(≤32)·아바타·About Me(≤190)를 별도로
// 보관한다. 전역 프로필(User.displayName/avatarKey/bio)을 덮어쓰지 않고 오버라이드만
// 둔다(채팅/멤버목록 표시 우선순위: ws nickname > 전역 displayName > handle/username,
// 아바타: ws avatarKey > 전역 avatarKey > 기본). 행 부재 = 오버라이드 없음(전역값 사용).
//
// 길이 한도는 nickname/workspaceBio 모두 DB(VarChar) + 앱 레이어 이중 방어한다.
// avatarKey 는 MinIO `ws-avatars/<wsId>/<userId>/` prefix. workspace/user 모두
// onDelete Cascade 라 워크스페이스/계정 삭제 시 자동 정리된다.
model WorkspaceMemberProfile {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @db.Uuid
  userId       String   @db.Uuid
  // FR-PS-06: 워크스페이스 닉네임(≤32). null = 전역 displayName 으로 폴백.
  nickname     String?  @db.VarChar(32)
  // FR-PS-06: 워크스페이스 아바타 MinIO 키. null = 전역 avatarKey 로 폴백.
  avatarKey    String?
  // FR-PS-06: 워크스페이스 About Me(≤190). null = 전역 bio 로 폴백(표시 패널은 S75).
  workspaceBio String?  @db.VarChar(190)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 멤버당 워크스페이스별 단일 프로필(upsert 대상).
  @@unique([workspaceId, userId])
  // 멤버목록 LEFT JOIN(workspaceId 스코프 + userId 매칭) lookup 가속.
  @@index([workspaceId, userId])
}

model WorkspaceMember {
  workspaceId           String        @db.Uuid
  userId                String        @db.Uuid
  // S61: `role` enum 은 시스템 역할 등급(@Roles guard) 의 1차 출처로 유지한다.
  // 커스텀 역할은 아래 `memberRoles`(MemberRole 조인)로 표현하며, 시스템 역할은
  // backfill 로 동등한 MemberRole 행을 함께 갖는다(role enum ↔ 시스템 Role 동기).
  role                  WorkspaceRole @default(MEMBER)
  joinedAt              DateTime      @default(now())
  // S67 (D13 / FR-W03·W12): 임시 멤버십 표식. temporary=true 초대로 수락한 멤버는
  // true 로 기록된다. S70 의 연결 종료 강퇴 배치(debounce)가 이 컬럼으로 대상을
  // 추린다(@@index([workspaceId, isTemporary])). S67 은 컬럼 + accept 기록까지만.
  isTemporary           Boolean       @default(false)
  // S63 (D12 / FR-RM07): 모더레이션 타임아웃 만료 시각. null = 음소거 아님. 미래
  // 시각이면 그 시각까지 SEND_MESSAGES/ADD_REACTIONS/USE_SLASH_COMMANDS 가 차단된다
  // (VIEW_CHANNEL/READ_HISTORY 는 유지). 만료는 lazy 체크(mutedUntil>now) — cron/
  // BullMQ 불요. UserChannelMute.mutedUntil(알림 뮤트)과는 별개 축이다.
  mutedUntil            DateTime?     @db.Timestamptz(6)
  // S69 (D13 / FR-W10): 이 멤버를 초대한 사용자(없으면 null — 공개 가입/레거시 row).
  // 링크 초대=invite.createdById · 이메일 초대=pending.invitedById · joinPublic=null 로
  // accept 경로에서 기록한다. 초대자 계정 삭제 시 SetNull(초대 이력은 남기되 FK 정리).
  invitedById           String?       @db.Uuid
  // S71 (D13 / FR-W07): 규칙 동의 시각. null = 미동의. 워크스페이스에 WorkspaceRule 이
  // 존재하는데 이 값이 null 이면 send/react 서버 게이트가 403 RULES_NOT_ACCEPTED 로
  // 차단한다(Fork-C). 규칙 0개면 게이트 무동작. additive nullable · backfill 없음(Fork A-1)
  // — 기존 멤버는 규칙 생성 전까지 null 이어도 게이트 무영향(규칙 부재).
  rulesAcceptedAt       DateTime?     @db.Timestamptz(6)
  // S71 (D13 / FR-W08): 관심사(Step2) 완료 시각. null = 미완료. 모든 단계 완료 판정의 1차
  // 출처(FE 오버레이 마운트 게이트). '건너뛰기'도 이 값을 세팅한다(채널/역할 미실행).
  onboardingCompletedAt DateTime?     @db.Timestamptz(6)
  // S71 (D13 / FR-W08 · 결정 4): SHORT_TEXT 질문 답변 저장소. [{ questionId, text }] 형태.
  // 별도 Answer 테이블을 두지 않는다(자유형 응답은 멤버 행에 동거). null = 응답 없음.
  onboardingAnswers     Json?
  // S72 (D13 / FR-W22): 이 멤버가 가입한 시점의 요청 IP 해시(sha256, hex 64자). joinPublic /
  // 초대 수락 / 신청 승인 진입점에서 기록한다. 멤버 ban 시 ModerationService 가 이 값을
  // BannedMember.ipHash 로 복사해, 같은 IP 의 후속 가입/수락을 soft-block(audit) 한다.
  // null = 미상 IP(NAT/프록시 미상) 또는 레거시 가입. 원시 IP 는 저장하지 않는다(해시만).
  ipHash                String?       @db.Char(64)

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // S69 (FR-W10): 초대자 표시 조인(프로필 패널). 초대자 계정 삭제 시 SetNull.
  invitedBy   User?        @relation("WorkspaceMemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  // S61 (FR-RM01/15): 이 멤버가 보유한 역할 조인. Role 삭제 시 onDelete Cascade
  // 로 자동 정리된다(FR-RM15).
  memberRoles MemberRole[]

  @@id([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
  // S67 (D13 / FR-W12): S70 임시 멤버 강퇴 배치가 (workspaceId, isTemporary) 로
  // 임시 멤버만 빠르게 스캔하기 위한 보조 인덱스.
  @@index([workspaceId, isTemporary])
  // S27 fix-forward(perf): keyset sort index for the grouped member list. The
  // list orders by (joinedAt, userId) within a workspace and (for < 1000
  // members) loads the whole set; this ordered index keeps that load + sort
  // O(N) instead of forcing a full sort of the workspace's member slice.
  @@index([workspaceId, joinedAt, userId])
}

// S63 (D12 / FR-RM06): 워크스페이스 영구 차단 목록. 멤버/비멤버 userId 를 모두 담을
// 수 있다(가입 전 차단도 가능). 초대 수락(invites.service.accept)에서 (workspaceId,
// userId) 존재 여부를 검사해 재진입을 막는다. 차단은 userId 기반(IP 차단은 범위 밖).
// FK 는 Workspace 만 CASCADE(워크스페이스 삭제 시 차단 행 정리). 대상/액터 userId 는
// 명시 FK 를 두지 않는다(비멤버 userId 도 담아야 하고, 사용자 삭제 경로는 별도 정책).
// @@id 복합키로 (workspaceId, userId) 당 1행을 보장한다(멱등 ban).
model BannedMember {
  workspaceId String   @db.Uuid
  userId      String   @db.Uuid
  bannedBy    String   @db.Uuid
  reason      String?  @db.VarChar(512)
  // S72 (D13 / FR-W22): ban 집행 시 대상 멤버의 마지막 가입 ipHash 를 복사해 둔 값.
  // 가입/초대 수락 진입점이 (workspaceId, ipHash) 로 이 행을 대조해 같은 IP 의 후속
  // 가입을 soft-block(PUBLIC/INVITE=audit · APPLY=차단) 한다. null = ban 대상 멤버의
  // ipHash 미기록(비멤버 ban·레거시) → IP 신호 없음(userId ban 만으로 차단).
  ipHash      String?  @db.Char(64)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@index([workspaceId, createdAt])
  // S72 (D13 / FR-W22): 가입/수락 IP 대조(WHERE workspaceId AND ipHash) 커버 인덱스.
  @@index([workspaceId, ipHash])
}

// S64 (D12 / FR-RM11): 메시지 신고 큐. 모든 멤버가 메시지를 카테고리별로 신고하고
// ADMIN/MODERATOR 가 큐를 열람해 처리(DISMISS/WARN/DELETE_MESSAGE/TIMEOUT/BAN)한다.
// (messageId, reporterId) 복합 유니크로 같은 신고자의 중복 신고를 막는다. resolved* 는
// 미처리 시 null. category/resolvedAction 은 enum 대신 넓은 String(shared-types Zod 가
// 검증)으로 두어 후속 카테고리/액션 추가 시 마이그레이션을 피한다(AuditLog.action 선례).
// FK: Workspace·Message 는 onDelete Cascade(워크스페이스/메시지 hard-delete 시 정리).
// reporterId/resolvedBy 는 명시 FK 를 두지 않는다(User 하드삭제 경로는 별도 정책 ·
// BannedMember 선례) — 표시 정보는 read-path 에서 best-effort 조인한다.
model ModerationReport {
  id             String    @id @default(uuid()) @db.Uuid
  workspaceId    String    @db.Uuid
  messageId      String    @db.Uuid
  channelId      String    @db.Uuid
  // S64 fix-forward (security A-6 = MEDIUM-2): 신고자 계정 하드삭제 시 ON DELETE SET NULL
  // 로 익명화한다(행은 보존 — 모더레이션 이력 유지). 따라서 nullable.
  reporterId     String?   @db.Uuid
  // 신고 카테고리(SPAM/HARASSMENT/HATE_SPEECH/INAPPROPRIATE/OTHER).
  category       String    @db.VarChar(32)
  reason         String?   @db.VarChar(512)
  // 처리 결과(DISMISS/WARN/DELETE_MESSAGE/TIMEOUT/BAN). 미처리 시 null.
  resolvedAction String?   @db.VarChar(32)
  resolvedBy     String?   @db.Uuid
  resolvedAt     DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  // S64 fix-forward (security A-6 = MEDIUM-2): channel 하드삭제 시 신고 행 함께 정리,
  // 신고자 계정 삭제 시 익명화(SET NULL). 정렬 커버 인덱스는 raw SQL 마이그레이션의
  // "ModerationReport_ws_queue_sort_idx" (NULLS FIRST · createdAt DESC) 가 담당한다.
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  reporter  User?     @relation("ModerationReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  @@unique([messageId, reporterId])
  @@index([workspaceId, resolvedAt, createdAt])
  @@index([messageId])
}

// S70 (D13 / FR-W06): 가입 신청(APPLY 모드). 신청자가 커스텀 질문(최대 5개) 응답과 함께
// 제출하고, ADMIN+ 가 승인/인터뷰·MODERATOR+ 가 거절을 처리한다. APPROVED 시 같은
// 트랜잭션에서 WorkspaceMember 가 생성된다. INTERVIEW 전환 시 신청자와 1:1 DM 이 자동
// 생성되고 그 채널 id 가 interviewChannelId 에 기록된다.
//
// @@unique([workspaceId, applicantId, status]) — 같은 (워크스페이스, 신청자, 상태) 조합당
// 1행. 같은 사용자가 PENDING 으로 두 번 신청하면 DB 유니크가 막지만, 서비스 레이어가 PENDING
// 중복을 선조회해 409(APPLICATION_PENDING_EXISTS)로 거부한다(DB 충돌 노출보다 명확한 에러).
// WITHDRAWN/REJECTED 후 재신청은 그 상태 행을 PENDING 으로 되살려(UPDATE) 유니크 충돌을
// 피한다(REJECTED 는 24h cooldown 을 서비스가 검사). status 전이(PENDING→APPROVED 등)는 행
// UPDATE 다. PK 는 cuid 대신 본 프로젝트 표준 uuid(@db.Uuid) 를 쓴다(전 모델 정합).
//
// FK: workspace·applicant 는 onDelete Cascade(워크스페이스/신청자 삭제 시 신청 정리),
// reviewedBy 는 SetNull(검토자 계정 삭제 시 이력은 남기고 FK 만 끊음). interviewChannelId 는
// 자동 생성 DM 채널 id 이나 명시 FK 는 두지 않는다(DM 채널 hard-delete 경로는 별도 정책 —
// ModerationReport.reporterId 와 동일한 best-effort 비-FK 식별자 패턴). additive 신규 테이블
// 이라 기존 row 영향 없음(backfill 불요 — 20260609000000_s70_member_application).
model WorkspaceMemberApplication {
  id                 String            @id @default(uuid()) @db.Uuid
  workspaceId        String            @db.Uuid
  applicantId        String            @db.Uuid
  status             ApplicationStatus @default(PENDING)
  // [{ questionId, answer }] — 커스텀 질문 응답(최대 5). 질문 카탈로그(OnboardingQuestion)는
  // 별도 carryover 라 S70 은 자유형 answers Json 으로 저장만 한다(shared-types Zod 가 형식 검증).
  answers            Json
  reviewedById       String?           @db.Uuid
  reviewNote         String?           @db.VarChar(500)
  interviewChannelId String?           @db.Uuid
  // S72 (D13 / FR-W22 · reviewer BLOCKER-1): 신청 제출(submit) 시점의 요청 IP 해시
  // (sha256, hex 64자). APPLY 는 신청자 IP(submit)와 승인자 IP(approve=admin)가 분리되므로,
  // approve 의 req.ip(=admin IP) 대신 submit 때 기록한 이 값을 승인 시 WorkspaceMember.ipHash
  // 로 복사한다 — 그래야 APPLY 가입자도 ban 시 BannedMember.ipHash 가 채워져 APPLY soft-block
  // 대조가 동작한다. null = 미상 IP(NAT/프록시 미상) 또는 레거시 신청. 원시 IP 는 저장 안 함.
  applicantIpHash    String?           @db.Char(64)
  createdAt          DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  applicant  User      @relation("WorkspaceMemberApplicationApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  reviewedBy User?     @relation("WorkspaceMemberApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([workspaceId, applicantId, status])
  // S70 fix-forward (perf MINOR): ADMIN 목록은 (workspaceId, status) 필터 + createdAt DESC
  // 정렬이므로 createdAt 까지 인덱스에 포함해 정렬도 커버한다(filesort 제거).
  @@index([workspaceId, status, createdAt])
  @@index([applicantId])
}

// S71 (D13 / FR-W07): 워크스페이스 규칙. 신규 멤버 첫 진입 시 전체화면 모달로 동의를
// 요구하며(최대 10개), 동의 전 메시지 전송·리액션이 서버에서 403 으로 차단된다(Fork-C).
// position 으로 표시 순서를 정하고 (workspaceId, position) 유니크로 충돌을 막는다.
// additive 신규 테이블이라 기존 row 영향 없음(reversible — down 에서 테이블 DROP).
model WorkspaceRule {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  position    Int
  title       String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // perf MINOR (S71 리뷰): @@unique([workspaceId, position]) 가 (workspaceId, position)
  // 조회·정렬을 이미 커버하므로 동일 컬럼의 @@index 는 중복(redundant)이라 제거했다.
  @@unique([workspaceId, position])
}

// S71 (D13 / FR-W08): 관심사 질문(최대 5). 선택지(options Json)는 [{ id, label, channelIds[],
// roleId? }] 형태로, 선택 시 channelIds 채널을 구독하고 roleId 역할을 부여한다(complete tx).
// type=SHORT_TEXT 는 선택지가 없고 답변을 WorkspaceMember.onboardingAnswers 에 저장한다.
// options 형식 검증은 shared-types Zod 가 담당한다(S70 application answers Json 선례).
// additive 신규 테이블이라 기존 row 영향 없음(reversible — down 에서 테이블·타입 DROP).
model OnboardingQuestion {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @db.Uuid
  position    Int
  type        QuestionType
  isRequired  Boolean      @default(false)
  label       String       @db.VarChar(200)
  options     Json
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, position])
}

// S71 (D13 / FR-W09): 워크스페이스 웰컴 설정(1:1 — workspaceId 가 PK). 완료 시 BullMQ 가
// 시스템 DM(message) 발송 + welcomeChannelId 입장 시스템 메시지를 비동기 게시한다. 설정이
// 없으면(행 부재) Step3 skip. welcomeChannel 하드삭제 시 SetNull(웰컴 설정은 유지하고 채널
// 참조만 끊음). additive 신규 테이블이라 기존 row 영향 없음(reversible — down 에서 테이블 DROP).
model WorkspaceWelcome {
  workspaceId      String  @id @db.Uuid
  welcomeChannelId String? @db.Uuid
  message          String? @db.VarChar(500)
  // 입장 후 권장 to-do 목록(최대 5 — shared-types Zod 강제). 없으면 null.
  todos            Json?

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  welcomeChannel Channel?  @relation("WorkspaceWelcomeChannel", fields: [welcomeChannelId], references: [id], onDelete: SetNull)
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  description String?
  position    Decimal   @db.Decimal(20, 10)
  // S15 (FR-CH-12): 카테고리 soft-delete. 삭제 시 deletedAt 을 찍고 소속 채널의
  // categoryId 를 NULL 로 끊는다(동일 트랜잭션). 동명 재사용은 부분 유니크
  // `(workspaceId, name) WHERE "deletedAt" IS NULL` (raw SQL 마이그레이션
  // 20260601100000_s15_category_soft_delete) 으로 보장한다 — Prisma @@unique 는
  // 부분 WHERE 를 표현할 수 없어 전체-테이블 @@unique 는 그 마이그레이션에서
  // DROP 한다(채널 partial-unique 와 동일 패턴, S12).
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  channels    Channel[]

  @@index([workspaceId, position])
  @@index([workspaceId, deletedAt])
}

model Channel {
  id                String      @id @default(uuid()) @db.Uuid
  // task-034-A: workspaceId is nullable — DIRECT channels live in the
  // global DM scope (no parent workspace). The DB CHECK in the
  // migration enforces "(type='DIRECT') OR (workspaceId IS NOT NULL)"
  // so non-DIRECT rows always have a workspace. The OR is intentionally
  // NOT XOR: 027-era DIRECT rows with a host workspaceId stay legal
  // for back-compat.
  // A partial UNIQUE index (task-034 reviewer HIGH fix) enforces
  // (name) uniqueness in the null-workspace DIRECT subset — postgres
  // treats NULL as distinct in standard unique indexes, so the plain
  // @@unique([workspaceId, name]) below doesn't close the
  // createOrGet race on its own.
  // Pre-migration prod audit: 0 DIRECT rows, so no backfill needed.
  workspaceId       String?     @db.Uuid
  categoryId        String?     @db.Uuid
  name              String
  // S20 (FR-DM-05): group DM 사용자 지정 표시명. `name` 은 멤버 set 으로부터
  // 파생된 dedup slug(`dm:`/`gdm:`)라 불변이므로, 사용자가 바꾸는 표시명은 이
  // 컬럼에 둔다. 1:1 DM·미설정·일반 채널은 NULL → list/listGroups 가
  // displayName ?? name 으로 렌더한다. additive nullable(기존 row 안전).
  displayName       String?
  // S20 (FR-DM-06): group DM 아이콘 MinIO object 키/URL. 미설정 NULL = 기본 아바타.
  // 업로드 시 storageKey 를 저장하고 list 응답에서 presignGet 으로 서명 URL 을
  // 만들거나(키 형태) 또는 절대 URL 을 그대로 노출한다(현재는 storageKey 보관).
  iconUrl           String?
  type              ChannelType @default(TEXT)
  topic             String?
  // S13 (FR-CH-10): 채널 설명. ≤500자는 zod(Create/UpdateChannelRequest)가
  // 강제하고 DB 는 VarChar(500) 으로 상한을 둔다. 전문검색용 GIN 식 인덱스
  // (to_tsvector('simple', coalesce(description,''))) 는 Prisma 가 표현할 수
  // 없어 20260601000000_s13_channel_description 마이그레이션 raw SQL 로만 둔다.
  description       String?     @db.VarChar(500)
  position          Decimal     @db.Decimal(20, 10)
  // S15 (FR-CH-08): 채널별 슬로우모드 간격(초). 0 이면 게이트 무동작. 송신
  // 경로(MessagesController.send)가 Redis `slowmode:{channelId}:{userId}` TTL 로
  // 집행하며, BYPASS_SLOWMODE 비트 보유자(OWNER/ADMIN baseline + 채널 override)는
  // 면제한다.
  slowmodeSeconds   Int         @default(0)
  // S51 (D10 / FR-PS-05): 핀 권한 채널 오버라이드. true(기본) = 채널 멤버 전체가 핀
  // 가능, false = MODERATOR/ADMIN 이상으로 제한(워크스페이스 ADMIN/OWNER 는 항상 가능).
  // PIN_MESSAGE(0x80) 집행 비트는 사용하지 않는다(MENTION_EVERYONE 카탈로그 0x80 과
  // 충돌 — D12 carryover) — 이 컬럼을 MessagesController.pin/unpin 게이트가 직접 검사한다.
  // default true 라 기존 row 안전(additive + reversible — 20260602800000_s51_pin_restrict_saved).
  memberCanPin      Boolean     @default(true)
  // S55 (D11 / FR-CH-18): 채널별 첨부 업로드 토글. false 면 upload-url 게이트가 403.
  // default true 라 기존 row 안전(additive + reversible — 20260603300000_s55_attachments_policy_gc).
  fileUploadEnabled Boolean     @default(true)
  // S55 (D11 / FR-AM-20): 채널별 최대 첨부 크기(바이트). null 이면 워크스페이스 설정 →
  // S3Service.maxBytes 순으로 폴백. BigInt(100MB 초과 표현 + 정밀도 보존).
  maxFileSizeBytes  BigInt?
  isPrivate         Boolean     @default(false)
  // S65 (D13 / FR-W01·W19): 워크스페이스 기본 채널 여부. 생성 시 #general 이 true 로
  // 시드되며, 기본 채널 변경(FR-W19) 시 이전 채널 false·신규 채널 true 로 토글된다
  // (단일 트랜잭션). Workspace.defaultChannelId 와 한 쌍으로 동기된다. default false
  // 라 기존 row 안전(additive + reversible).
  isDefault         Boolean     @default(false)
  // S19 (FR-DM-08/09): 그룹 DM owner. group(`gdm:%`) DM 에서만 의미가 있다 —
  // 1:1 DM(`dm:%`)·일반 채널은 NULL. 멤버 추가/강퇴는 owner 만, 나가기 시 owner
  // 가 떠나면 잔여 멤버 중 joinedAt 최古로 자동 승계한다. onDelete SET NULL 로
  // owner User 하드삭제 시 승계 훅 없이 NULL 로 끊긴다(승계 훅은 carryover).
  // 마이그레이션이 기존 gdm 채널의 owner 를 joinedAt/createdAt 최古 멤버로 backfill.
  ownerId           String?     @db.Uuid
  archivedAt        DateTime?
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  workspace                Workspace?                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // S65 (D13 / FR-W19): 이 채널을 기본 채널로 가리키는 워크스페이스(역참조). 채널
  // hard-delete 시 그 쪽 FK 가 SetNull 로 끊긴다(Workspace.defaultChannel).
  defaultForWorkspaces     Workspace[]                 @relation("WorkspaceDefaultChannel")
  category                 Category?                   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  owner                    User?                       @relation("ChannelOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  messages                 Message[]
  attachments              Attachment[]
  // S54 (D11 / FR-AM-03): presigned 업로드 세션. onDelete Cascade.
  attachmentUploadSessions AttachmentUploadSession[]
  overrides                ChannelPermissionOverride[]
  mutes                    UserChannelMute[]
  // S43 (FR-CH-15): 이 채널을 즐겨찾기한 행. onDelete Cascade.
  favorites                UserChannelFavorite[]
  // S64 fix-forward (security A-6 = MEDIUM-2): 이 채널 메시지에 대한 신고 행들.
  // 채널 하드삭제 시 ON DELETE CASCADE 로 함께 정리된다.
  moderationReports        ModerationReport[]
  // S71 (D13 / FR-W09): 이 채널을 웰컴 입장 메시지 채널로 가리키는 웰컴 설정(역참조).
  // 채널 하드삭제 시 그 쪽 FK 가 SetNull 로 끊긴다(WorkspaceWelcome.welcomeChannel).
  welcomeForWorkspaces     WorkspaceWelcome[]          @relation("WorkspaceWelcomeChannel")

  // S12 (FR-CH-03): channel-name uniqueness within a workspace is enforced by a
  // PARTIAL unique index `(workspaceId, name) WHERE "deletedAt" IS NULL`
  // (raw SQL in 20260531180000_s12_channel_name_partial_unique — Prisma's
  // @@unique can't express the partial WHERE). A soft-deleted row no longer
  // occupies its name, so the name is immediately reusable. The full-table
  // @@unique([workspaceId, name]) was dropped in that migration.
  // S65 fix-forward (perf MODERATE-1): updateDefaultChannel 의 `WHERE workspaceId
  // AND isDefault=true` updateMany 를 가속하는 PARTIAL 인덱스 `(workspaceId,
  // isDefault) WHERE "isDefault" = true` 가 raw SQL(20260604100000_s65_channel_
  // default_partial_index)로 존재한다 — Prisma @@index 는 부분 WHERE 를 표현할 수
  // 없어 여기 선언하지 않는다. 워크스페이스당 true 행은 보통 ≤1개라 매우 작다.
  @@index([workspaceId, categoryId, position])
  @@index([workspaceId, deletedAt])
}

// Task-012-D: per-channel permission override. principalType = 'USER'
// (principalId = User.id UUID) or 'ROLE' (principalId = WorkspaceRole
// literal: OWNER/ADMIN/MEMBER). Masks are bitfields per
// apps/api/src/auth/permissions.ts; DENY > ALLOW.
model ChannelPermissionOverride {
  id            String    @id @default(uuid()) @db.Uuid
  channelId     String    @db.Uuid
  principalType String    @db.VarChar(8)
  principalId   String    @db.VarChar(64)
  // S61 (FR-RM03): allow/deny 마스크를 Int → BigInt 로 전환한다. ADR-4 카탈로그의
  // ADMINISTRATOR(1n<<63n) 비트까지 무손실로 표현하기 위함이다. 기존 0~0xFF 값은
  // BigInt 로 무손실 승격된다(마이그레이션 ALTER TYPE ... USING). principalType=ROLE
  // 의 principalId 는 시스템 역할 리터럴(레거시) 또는 Role.id(UUID·신규)를 담는다.
  allowMask     BigInt    @default(0)
  denyMask      BigInt    @default(0)
  // S17 (FR-DM-17 / FR-TH-19): DM 가시성 하한선. DM·그룹 DM 의 USER 멤버십
  // row(이 모델이 DM 멤버십의 canonical per-(user,channel) 레코드 — S16)에만
  // 의미가 있다. NULL = 전체 히스토리 가시(비-DIRECT 채널·ROLE override·legacy
  // DM row 는 항상 NULL → 필터 무영향). DM 개설/복원(숨겨진 DM 재진입) 시점에
  // 그 시각으로 세팅되며, 메시지 list(before/after/around/initial) 전 경로가
  // `createdAt >= visibleFrom` 으로 요청자 본인 시점 이전 메시지를 제외한다.
  visibleFrom   DateTime? @db.Timestamptz
  // S19 (FR-DM-07/08/09): DM 멤버십 가입/탈퇴 시각. joinedAt = 그룹 DM 가입(개설·
  // 추가·재진입) 시각으로 owner 승계 정렬(joinedAt ASC 최古)의 1차 키다. leftAt =
  // soft-leave(나가기/강퇴) 시각 — **1차 멤버십 판정에는 쓰지 않는** 보조 컬럼
  // (감사·승계·재진입 정렬용)이다. soft-leave 는 leftAt=now() 와 allowMask=0
  // (denyMask=0)을 같은 UPDATE 에서 원자적으로 세팅하므로, 기존 read-path(allowMask&1>0)
  // 가 코드 변경 없이 leaver/kicked 를 즉시 비멤버 취급한다(★ 불변 계약). row 는
  // DELETE 하지 않고 재진입 시 UPDATE 로 복원한다(unique 충돌 회피). 두 컬럼 모두
  // nullable — legacy DM row·ROLE override·비-DIRECT 채널은 NULL.
  joinedAt      DateTime? @db.Timestamptz
  leftAt        DateTime? @db.Timestamptz
  // S20 (FR-DM-10): per-user DM 숨김 상태. NULL = 사이드바 DM 목록에 표시,
  // NOT NULL = 숨김(숨긴 시각). S17 visibleFrom / S19 joinedAt·leftAt 과 같은
  // USER 멤버십 row 에 동거하는 per-(user,channel) 상태이며, soft-leave
  // (allowMask=0 + leftAt)와 **독립적**이다 — 멤버십은 유지하되 목록에서만
  // 가린다. list/listGroups 가 hiddenAt IS NULL 인 DM 만 반환하고, 상대방 새
  // 메시지 도착 시 수신자(보낸 본인 제외) hiddenAt 을 NULL 로 자동 복원한다.
  // 자동 복원은 visibleFrom 을 재설정하지 않으므로 과거 메시지는 그대로 보인다.
  // legacy DM row·ROLE override·비-DIRECT 채널은 NULL(필터 무영향).
  hiddenAt      DateTime? @db.Timestamptz
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  // S19 (MED fix-forward): 그룹 DM 활성 멤버 조회 + owner 승계 정렬(joinedAt ASC)
  // 은 부분 인덱스 `CPO_dm_active_members_idx (channelId, joinedAt)
  // WHERE principalType='USER' AND leftAt IS NULL` (raw-SQL 마이그레이션
  // 20260601300000_s19_dm_membership_owner_privacy)가 커버한다. Prisma @@index 는
  // partial WHERE 를 표현할 수 없다. 이전에 정합용으로 둔 전체-컬럼
  // `@@index([channelId, joinedAt])` 는 부분 인덱스와 선두 컬럼이 같아 활성멤버
  // 쿼리에 잉여였고(게다가 그 전체 인덱스를 만드는 CREATE INDEX 가 마이그레이션에
  // 없어 schema↔migration drift 였다), 제거해 부분 인덱스 하나만 유지한다.

  @@unique([channelId, principalType, principalId])
  @@index([channelId])
}

// S61 (D12 / FR-RM01·02·15): 커스텀 Role 엔티티. 워크스페이스당 시스템 5역할
// (OWNER·ADMIN·MODERATOR·MEMBER·GUEST)을 시드하고, ADMIN+ 가 커스텀 역할을
// 추가한다. permissions 는 ADR-4 카탈로그 BigInt 비트필드(packages/shared-types/
// src/permissions.ts 단일 출처)다. position 은 높을수록 상위(서열·계층 판정).
// 삭제 시 MemberRole(onDelete Cascade) 자동 삭제 + 해당 roleId 의
// ChannelPermissionOverride(principalType=ROLE) 삭제(서비스에서 처리) +
// 보유 멤버 perms 캐시 DEL(>1000명 BullMQ 배치).
model Role {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  name        String   @db.VarChar(64)
  // "#RRGGBB" 또는 null(색상 없음). Char(7) 고정.
  colorHex    String?  @db.Char(7)
  // 높을수록 상위. 시스템 역할 기본: OWNER 500 / ADMIN 400 / MODERATOR 300 /
  // MEMBER 200 / GUEST 100(10/100 단위 간격으로 커스텀 삽입 여지).
  position    Int
  // ADR-4 카탈로그 BigInt 비트필드. OWNER 시스템 역할은 ADMINISTRATOR 고정.
  permissions BigInt   @default(0)
  // true = 시스템 고정 역할(name/position/삭제 불가). false = 커스텀.
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberRoles MemberRole[]

  @@unique([workspaceId, name])
  @@index([workspaceId, position])
}

// S61 (D12 / FR-RM01·15): 멤버 ↔ 역할 다대다 조인. Role 삭제 시 onDelete Cascade
// 로 자동 삭제(FR-RM15). WorkspaceMember 삭제(멤버 탈퇴) 시에도 Cascade.
model MemberRole {
  workspaceId String   @db.Uuid
  userId      String   @db.Uuid
  roleId      String   @db.Uuid
  assignedAt  DateTime @default(now()) @db.Timestamptz(6)
  // 부여한 액터 userId(감사용). 시스템 backfill 행은 null.
  assignedBy  String?  @db.Uuid

  member WorkspaceMember @relation(fields: [workspaceId, userId], references: [workspaceId, userId], onDelete: Cascade)
  role   Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId, roleId])
  @@index([roleId])
  @@index([workspaceId, userId])
}

// S62 (D12 / FR-RM17): 모더레이션/관리 감사 로그. append-only(INSERT 전용 ·
// common/audit/audit.service). S63 kick/ban/timeout 이 같은 테이블을 공유한다 —
// `action` 은 enum 대신 넓은 String 으로 두어(예 ADMINISTRATOR_CHANNEL_BYPASS ·
// MEMBER_KICK · MEMBER_BAN · MEMBER_TIMEOUT) 후속 슬라이스가 마이그레이션 없이
// 새 action 을 추가할 수 있게 한다. details 는 임의 컨텍스트(Json·nullable).
// onDelete Cascade: 워크스페이스 삭제 시 감사 로그도 함께 정리(데이터 잔존 방지).
model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  // 행위 주체(액터) userId. 시스템 자동 기록도 항상 액터를 가진다(필수).
  actorId     String   @db.Uuid
  // 대상 엔티티(사용자/역할/메시지 등) id. action 에 따라 의미가 달라 nullable.
  targetId    String?  @db.Uuid
  // 관련 채널. 채널 무관 action(역할 변경 등)은 null.
  channelId   String?  @db.Uuid
  // 모더레이션/관리 액션 키(넓은 String enum — 마이그레이션 없이 확장).
  action      String   @db.VarChar(64)
  // 부가 컨텍스트(요구 권한·이전/이후 값 등). 없으면 null.
  details     Json?
  // S72 (D13 / FR-W22): 요청 IP 해시(sha256 hex 64자). SUSPICIOUS_JOIN / SUSPICIOUS_JOIN_
  // THRESHOLD 액션에만 채워지며(그 외 액션은 null), 24h 내 동일 ipHash 의 SUSPICIOUS_JOIN
  // 건수 카운트(threshold 평가)에 쓴다. 원시 IP 는 저장하지 않는다(해시만).
  ipHash      String?  @db.Char(64)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, action, createdAt])
  // S64 fix-forward (perf B-3 = MODERATE-3): actorId 필터(WHERE actorId=…) 커버 인덱스.
  @@index([workspaceId, actorId, createdAt])
  @@index([channelId, createdAt])
  // S72 (D13 / FR-W22): 24h SUSPICIOUS_JOIN 카운트(WHERE workspaceId AND ipHash AND
  // createdAt>=since) 커버 인덱스.
  @@index([workspaceId, ipHash, createdAt])
}

model Message {
  id              String    @id @default(uuid()) @db.Uuid
  channelId       String    @db.Uuid
  authorId        String    @db.Uuid
  content         String
  contentPlain    String
  mentions        Json      @default("{\"users\":[],\"channels\":[],\"everyone\":false}")
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  // client-generated uuid for POST retry dedupe — null when no header was sent.
  // S03 (ADR-2 / FR-MSG-05): uniqueness is USER-scoped via a PARTIAL unique
  // index `(authorId, idempotencyKey) WHERE idempotencyKey IS NOT NULL`
  // created in raw SQL (schema-level `@@unique` would index every NULL row
  // too, and Prisma can't express the partial WHERE). User A's key reused by
  // user B yields a new row. The legacy channel-scoped index is retained
  // through the expand window and dropped in the same migration's down.sql.
  // `nonce` (clientNonce) lives separately as an optimistic-UI echo only;
  // we store it on send so reconnect-resend dedupe is observable.
  idempotencyKey  String?   @db.Uuid
  // S03 (FR-MSG-04): clientNonce echo. UUID v4 the client sends in the POST
  // body; mirrored on the message:created WS event for optimistic swap.
  // Additive nullable — system/legacy rows are NULL. NOT a dedupe key
  // (that is idempotencyKey); persisted for observability + reconnect flows.
  nonce           String?   @db.Uuid
  // task-014-B: single-level threads. Self-FK; ON DELETE SET NULL means
  // a hard-deleted root turns its replies into pseudo-roots (purge
  // worker is the only path that hard-deletes). Soft delete leaves the
  // row intact and hides the content at the DTO layer. Single-level
  // depth is enforced at the service — parent-of-parent must be NULL.
  parentMessageId String?   @db.Uuid

  // ── S33 (D04 / FR-TH-16 / FR-TH-17) — 스레드 비정규화 카운터 ───────────────
  // 루트 메시지에만 의미가 있다(답글 행은 항상 0/NULL). 채널 메시지 목록의
  // threadMeta(FR-TH-16)를 GROUP BY 집계 없이 컬럼 직접 반환으로 해석하기 위한
  // read-path 비정규화 캐시다. 답글 send/soft-delete 의 단일 $transaction 안에서
  // 원자적으로 갱신한다(FR-TH-17 기초 — DELETE 원자성/broadcast 강화는 S34).
  //   replyCount    — 비삭제(deletedAt IS NULL) 답글 수. send +1, soft-delete
  //                   GREATEST(0, -1). DEFAULT 0 이라 기존 row 안전(additive).
  //   latestReplyAt — 마지막 답글 createdAt. 답글 0개면 NULL. 답글 send 시
  //                   그 createdAt 으로 갱신. soft-delete 시점에는 굳이 되감지
  //                   않는다(1시간 재집계 job 이 drift 만 정정 — S34/운영).
  // 마이그레이션 20260602000000_s33_thread_reply_counters 가 기존 루트 행을
  // backfill 한다(서브쿼리 COUNT/MAX). additive + reversible(down.sql DROP).
  replyCount    Int       @default(0)
  latestReplyAt DateTime? @db.Timestamptz

  // ── S38 (D04 / FR-TH-13) — 스레드 잠금 ────────────────────────────────────
  // 루트 메시지에만 의미가 있다(답글 행은 항상 false). OWNER/ADMIN 이 스레드를
  // 잠그면 true 가 되고, 잠긴 스레드에서 MEMBER 이하의 답글 POST 는 controller
  // 게이트가 403 THREAD_LOCKED 로 막는다(OWNER/ADMIN 면제). default false 라 기존
  // row 안전(additive + reversible — 마이그레이션 20260602300000). PATCH
  // /messages/:id/thread/lock {locked} 가 토글하며 thread:lock:changed 를 emit 한다.
  threadLocked Boolean @default(false)

  // task-015-B: Postgres-generated tsvector column for FTS. Marked
  // `Unsupported` because Prisma 5.22 doesn't model tsvector natively;
  // the column is populated by the DB via GENERATED ALWAYS AS, so we
  // never write to it. SELECT paths that need FTS use $queryRaw.
  search_tsv Unsupported("tsvector")?

  // task-044-iter2: pinned messages. NULL = 미고정. Discord-parity cap
  // 50/channel enforced at service layer. Author 가 일반 MEMBER 라도
  // OWNER/ADMIN 이 pin 할 수 있어 pinnedBy 는 author 와 다를 수 있다.
  // S29 (FR-S05): 검색 `is:pinned` 은 별도 컬럼 없이 `pinnedAt IS NOT NULL`
  // 을 그대로 쓴다(pin/unpin 이 advisory-lock 아래 원자 유지 — 중복 컬럼 회피).
  pinnedAt DateTime? @db.Timestamptz
  pinnedBy String?   @db.Uuid

  // ── S29 (FR-S05 / ADR-2): 검색 수식어 `has:` 용 비정규화 boolean ──────────
  // send/edit 시점에 1회 계산해 박는 read-path 캐시. hasLink 는 mrkdwn AST 의
  // `link` 노드(allowlist 스킴) 유무로, hasImage/hasFile 은 연결된 finalized
  // Attachment.kind(IMAGE / FILE·VIDEO)로 판정한다. 전부 NOT NULL DEFAULT false
  // 라 기존 row 안전(additive). 검색 SQL 이 partial index 와 합성해 sparse scan.
  hasLink  Boolean @default(false)
  hasImage Boolean @default(false)
  hasFile  Boolean @default(false)

  // ── S01 (ADR-2 카노니컬 additive 토대) ────────────────────────────────────
  // expand-contract: 이번 슬라이스는 ADDITIVE 만. 신규 컬럼은 전부 nullable
  // 또는 default 동반이라 기존 row 가 안전하다. 기존 `content` / `contentPlain`
  // 컬럼은 그대로 유지(병행) — cuid2 PK 전환과 raw/ast 백필은 별도 트랙.
  //
  // contentRaw : 원본 mrkdwn (편집 diff용). 기존 row 는 NULL — 서비스
  //   레이어가 읽을 때 `content` 로 폴백한다. 신규 write 경로가 채운다.
  contentRaw     String?     @db.Text
  // contentAst : 파싱된 rich_text AST(JSONB). 구조 계약은
  //   packages/shared-types RichTextRootSchema. 기존 row 는 NULL.
  contentAst     Json?
  // contentPlainV2 : ADR-2 contentPlain 의 신규 nullable 슬롯. 기존 NOT NULL
  //   `contentPlain` 컬럼과 병행한다(기존 컬럼 타입/제약 변경 금지 규칙).
  //   백필 완료 후 contract 단계에서 단일화한다.
  contentPlainV2 String?     @db.Text
  // version : 낙관적 잠금 버전. default 0 이라 기존 row 는 자동 0.
  version        Int         @default(0)
  // seq : 채널 단위 단조 증가(Redis INCR seq:{channelId}) 발급값 영속 사본.
  //   힌트 용도이며 렌더 정렬 기준은 아님(D17). 기존 row 는 NULL.
  seq            BigInt?
  // authorType : USER | BOT | SYSTEM. default USER 라 기존 row 안전(ADR-2).
  authorType     AuthorType  @default(USER)
  // S04 (ADR-2 / FR-MSG-19): 메시지 타입. default DEFAULT 라 기존 row 안전
  // (additive + reversible). SYSTEM_* 는 시스템 행 렌더 + grouped=false 강제.
  type           MessageType @default(DEFAULT)
  // S35 (D04 / FR-TH-06 / FR-TH-14): 스레드→채널 broadcast 표식. 답글 send 시
  // 'Also send to #channel' 체크가 켜지면, send tx 안에서 별도의
  // SYSTEM_THREAD_BROADCAST 행을 채널 타임라인에 동시 게시하고 그 행에
  // isBroadcast=true 를 박는다(parentMessageId = thread root). default false 라
  // 기존 row 안전(additive + reversible — 마이그레이션 20260602100000_s35_thread_broadcast).
  //   - 채널 가시성: rawList 의 roots-only(parentMessageId IS NULL) 필터에
  //     `OR "isBroadcast"` 예외를 더해 broadcast 행을 채널에 노출한다.
  //   - FR-TH-14 채널 미읽 포함/삭제 시 정확히 1 감소는 ThreadReadState 와
  //     함께 S36 에서 마무리한다(이 슬라이스는 플래그·게시·가시성만).
  isBroadcast    Boolean     @default(false)

  channel          Channel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author           User                 @relation(fields: [authorId], references: [id])
  attachments      Attachment[]
  reactions        MessageReaction[]
  parent           Message?             @relation("MessageReplies", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies          Message[]            @relation("MessageReplies")
  threadFollowers  ThreadSubscription[] @relation("MessageThreadFollowers")
  // S36 (D04·D09 / FR-RS-12): 이 메시지를 스레드 루트로 가지는 읽음 커서들.
  // 루트 hard delete(운영 purge) 시 ON DELETE CASCADE 로 함께 삭제된다(고아
  // ThreadReadState 방지 — PRD FR-TH 엣지케이스 정합).
  threadReadStates ThreadReadState[]    @relation("MessageThreadReadStates")
  // S05 (FR-MSG-06): 편집 이력 스냅샷(ring buffer cap 10). 메시지 hard
  // delete 시 Cascade 로 함께 정리됩니다.
  editHistory      MessageEditHistory[] @relation("MessageEditHistory")
  // S51 (D10 / FR-PS-07): 이 메시지를 개인 저장함에 담은 SavedMessage 행들. 메시지
  // hard delete(운영 purge) 시 Cascade. soft-delete 는 Cascade 가 처리하지 않으므로
  // softDelete tx 가 SavedMessage.messageDeletedAt 을 직접 채운다(비정규화 동기화).
  savedBy          SavedMessage[]
  // S60 (D11 / FR-RC07/08 · FR-AM-13~16): 본문 URL 의 비동기 unfurl 결과(OG 카드).
  // UnfurlProcessor(BullMQ)가 메시지 발화 후 fire-and-forget 으로 채워 넣고,
  // message:embed_updated 이벤트로 채널 룸에 push 한다. 메시지 hard delete(운영 purge)
  // 시 ON DELETE CASCADE 로 함께 정리된다. 사후 suppress 는 행 삭제가 아니라
  // suppressedAt 표식으로 처리한다(read-path 가 suppressedAt IS NULL 만 노출).
  embeds           MessageEmbed[]
  // S64 (D12 / FR-RM11): 이 메시지에 대한 신고 행들. 메시지 hard delete(운영 purge)
  // 시 ON DELETE CASCADE 로 함께 정리된다(soft-delete 는 행을 유지하므로 신고도 보존).
  reports          ModerationReport[]
  // S29 (FR-S05): has: 필터용 partial index `(channelId) WHERE hasX = true`
  // 3종은 raw-SQL migration 20260601900000_s29_search_denormalized_flags 가
  // 생성합니다(Prisma @@index 가 partial WHERE 미지원이라 여기엔 선언 불가).

  // pagination primary path — matches ORDER BY createdAt DESC, id DESC with
  // row-value comparison WHERE (createdAt, id) < ($1, $2).
  @@index([channelId, createdAt, id])
  // S01 (ADR-2 / FR-RT-18): 단순 ID 조회 보조 + cuid2 커서(id DESC) 경로.
  @@index([channelId, id])
  // includeDeleted=false default path (soft-delete filter).
  @@index([channelId, deletedAt, createdAt])
  @@index([authorId])
  // thread replies list — ORDER BY createdAt ASC for the ThreadPanel.
  // Partial index `(channelId, createdAt DESC) WHERE parentMessageId IS NULL`
  // + the replies index `(parentMessageId, createdAt ASC)` are defined in
  // the raw-SQL migration (Prisma's @@index doesn't support partial WHERE).
  @@index([parentMessageId, createdAt])
  // task-044-iter2: pinned list — 채널별 pinned ORDER BY pinnedAt DESC.
  // Partial WHERE pinnedAt IS NOT NULL 은 raw-SQL migration 으로 보강합니다
  // (Prisma @@index 가 partial 미지원).
  @@index([channelId, pinnedAt])
}

// ── S60 (D11 / FR-RC07/08/09/21 · FR-AM-13~16) — 링크 unfurl 결과 ────────────
// 메시지 본문에서 추출한 URL 의 비동기 OG/Twitter-Card 메타 fetch 결과입니다.
// UnfurlProcessor(BullMQ · concurrency 2)가 메시지 발화 트랜잭션과 분리해 fire-and-
// forget 으로 채웁니다(전송 실패 영향 0). 한 메시지에 최대 LINK_PREVIEW_CAP(3)개의
// embed 행이 생길 수 있습니다.
//   - normalizedUrl/cacheKey : normalizeUrl()(scheme+host 소문자·utm_*/fbclid/gclid
//     제거·trailing slash 제거)의 결과와 그 SHA-256(64 hex). Redis 캐시 키 + DB 중복
//     방지(@@unique [messageId, cacheKey])의 정합 출처입니다.
//   - imageKey : OG 이미지를 MinIO 에 캐시한 object key(이미지 없으면 NULL). 직접
//     presigned 노출 대신 /links/embed-image/:id 프록시 뒤에서만 서빙합니다(FR-RC21).
//   - suppressedAt/By : 사후 suppress(작성자 또는 MANAGE_MESSAGES) 표식. 행 삭제가
//     아니라 표식으로 처리해 동일 URL 재추출 시 깜빡임을 막습니다(FR-AM-16/RC08).
// 마이그레이션 20260603400000_s60_message_embed 가 CREATE TABLE + 인덱스 + FK CASCADE
// 를 만들고 down.sql 이 역순 DROP 합니다(reversible · NO CONCURRENTLY).
model MessageEmbed {
  id            String    @id @default(uuid()) @db.Uuid
  messageId     String    @db.Uuid
  url           String    @db.Text
  normalizedUrl String    @db.Text
  cacheKey      String    @db.VarChar(64)
  title         String?   @db.Text
  description   String?   @db.Text
  siteName      String?   @db.VarChar(255)
  imageKey      String?   @db.VarChar(512)
  statusCode    Int
  fetchedAt     DateTime  @db.Timestamptz(6)
  suppressedAt  DateTime? @db.Timestamptz(6)
  suppressedBy  String?   @db.Uuid
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // 메시지별 embed 조회(read-path 조인) + 동일 메시지 내 동일 URL 중복 방지.
  @@unique([messageId, cacheKey])
  @@index([messageId])
  @@index([cacheKey])
}

// Task-013-B: per-message reactions. `emoji` is the literal unicode
// string as picked; VARCHAR(64) gives room for ZWJ sequences. API
// enforces ≤4 codepoint cap on top. (messageId, userId, emoji) is
// unique so POST is naturally idempotent — see ReactionsService.
model MessageReaction {
  id            String   @id @default(uuid()) @db.Uuid
  messageId     String   @db.Uuid
  userId        String   @db.Uuid
  emoji         String   @db.VarChar(64)
  // S41 (FR-EM06 / FR-RC20): 커스텀 이모지 반응이면 이 컬럼이 참조 CustomEmoji.id
  // 를 담는다(유니코드 반응이면 NULL). `emoji` 컬럼에는 일관 식별자 `:name:` 를
  // 함께 저장해, 커스텀 이모지가 삭제돼 customEmojiId 가 SetNull 로 풀려도 원래
  // 슬러그가 보존된다(UI placeholder + 툴팁). onDelete: SetNull 이라 CustomEmoji
  // 삭제 시 반응 행 자체는 보존되고 이 FK 만 NULL 로 풀린다(반응 카운트 유지).
  customEmojiId String?  @db.Uuid
  createdAt     DateTime @default(now())

  message     Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  customEmoji CustomEmoji? @relation(fields: [customEmojiId], references: [id], onDelete: SetNull)

  @@unique([messageId, userId, emoji])
  @@index([messageId, emoji])
  @@index([customEmojiId])
}

// S05 (FR-MSG-06 / FR-RC16): 메시지 편집 이력 스냅샷.
// 편집(PATCH) 시 직전 본문(contentRaw/contentAst/contentPlain)을 한 행으로
// 적재합니다. `version` 은 스냅샷 당시(편집 전) 메시지 version 입니다. 채널당
// 메시지별 ring buffer cap 은 서비스 레이어에서 10 으로 enforce 하며, 11번째
// 편집 시 가장 오래된 version 1개를 DELETE 합니다(DB 제약 아님 — 운영 유연성).
// additive only — 신규 테이블이라 기존 row 영향 없음. seed 결정성 무관.
model MessageEditHistory {
  id           String   @id @default(uuid()) @db.Uuid
  messageId    String   @db.Uuid
  // 스냅샷 당시(편집 전) 메시지 version.
  version      Int
  // 편집 전 본문 스냅샷. contentRaw 는 legacy row 에서 NULL 가능.
  contentRaw   String?  @db.Text
  contentAst   Json?
  contentPlain String   @db.Text
  // 스냅샷 생성(=해당 편집 발생) 시각.
  editedAt     DateTime @db.Timestamptz
  createdAt    DateTime @default(now())

  message Message @relation("MessageEditHistory", fields: [messageId], references: [id], onDelete: Cascade)

  // ring buffer 정렬(version asc/desc) + (messageId, version) 조회 경로.
  @@index([messageId, version])
}

enum AttachmentKind {
  IMAGE
  VIDEO
  FILE
}

// S54 (D11 / FR-AM-03): 첨부 후처리 상태. PENDING(생성·세션 링크 직후) → PROCESSING
// (썸네일/메타 추출 진행 — Sharp/ffprobe 는 S55+ OUT) → READY(노출 가능) | FAILED(후처리
// 실패) | BLOCKED(보안 거부). S54 는 PENDING 으로 생성만 하고 비동기 파이프라인은 후속.
enum AttachmentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
  BLOCKED
}

model Attachment {
  id                 String         @id @default(uuid()) @db.Uuid
  channelId          String         @db.Uuid
  messageId          String?        @db.Uuid
  uploaderId         String         @db.Uuid
  clientAttachmentId String?        @db.Uuid
  kind               AttachmentKind
  mime               String         @db.VarChar(127)
  sizeBytes          BigInt
  storageKey         String
  originalName       String
  finalizedAt        DateTime?
  createdAt          DateTime       @default(now())

  // ── S54 (D11) 확장 — 전부 nullable/@default (additive, 무회귀) ──────────────
  // 썸네일 객체 키(이미지/비디오 미리보기). 후처리 파이프라인(S55+)이 채움. null=없음.
  thumbnailKey     String?
  // 서버가 magic-byte 재검증으로 확정한 실제 MIME(declared 와 다를 수 있음).
  storedMimeType   String?          @db.VarChar(127)
  // filename 에서 추출한 소문자 확장자(점 제외, 예: "png"). 차단/교차검증용.
  extension        String?          @db.VarChar(20)
  // 이미지/비디오 픽셀 크기(클라가 complete 시 신고 — S54 는 신뢰 경계 밖, 표시용).
  width            Int?
  height           Int?
  // 오디오/비디오 길이(초). 후처리 ffprobe 는 S55+.
  duration         Float?
  // 대체 텍스트(접근성). 최대 2000자.
  altText          String?          @db.VarChar(2000)
  // 스포일러 표식(클릭 전 블러).
  isSpoiler        Boolean          @default(false)
  // 메시지 내 다중 첨부 정렬 순서(complete 시 클라가 지정).
  sortOrder        Int              @default(0)
  // 메시지/채널에 링크된 시각(complete 성공 시점). finalizedAt 과 별개 — 세션 기반 완료.
  linkedAt         DateTime?        @db.Timestamptz
  // 후처리 상태(기본 PENDING).
  processingStatus AttachmentStatus @default(PENDING)

  channel  Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploaderId], references: [id])

  // Indexes are created in the migration as partial indexes (Prisma
  // has no @@index-with-WHERE syntax). See
  // 20260421000000_add_attachment_table/migration.sql.
}

// S54 (D11 / FR-AM-03/27): presigned 업로드 세션. upload-url 단계에서 1행 생성하고
// complete 단계에서 completed=true 로 닫는다. magic-byte 재검증 + ACL 재검증 후
// Attachment 로 승격된다. 만료(expiresAt < now)되거나 미발견인 세션의 complete 는 거부.
// (uploaderId, completed, expiresAt) 복합 인덱스는 FR-AM-27 의 "동시 미완료 세션 20개"
// 카운트 쿼리(WHERE uploaderId=? AND completed=false AND expiresAt>now)를 위한 것.
model AttachmentUploadSession {
  id         String   @id @default(uuid()) @db.Uuid
  uploaderId String   @db.Uuid
  channelId  String   @db.Uuid
  filename   String   @db.VarChar(255)
  extension  String?  @db.VarChar(20)
  sizeBytes  BigInt
  mimeType   String   @db.VarChar(127)
  storageKey String
  expiresAt  DateTime @db.Timestamptz
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())

  uploader User    @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  channel  Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([uploaderId])
  @@index([expiresAt])
  // FR-AM-27: 동시 미완료 세션 카운트 전용 복합 인덱스.
  @@index([uploaderId, completed, expiresAt])
}

// S55 (D11 / FR-AM-20): 워크스페이스 첨부 정책(1:1 Workspace). maxFileSizeBytes 는
// 채널 오버라이드가 없을 때의 워크스페이스 기본 상한(null = S3Service.maxBytes 폴백).
// blockedExtensions 는 전역 BLOCKED_EXTENSIONS 와 합집합으로 적용되는 워크스페이스
// 추가 차단 목록. additive 신규 테이블 — 기존 row 영향 없음. Workspace 삭제 시 Cascade.
model WorkspaceSetting {
  id                String   @id @default(uuid()) @db.Uuid
  workspaceId       String   @unique @db.Uuid
  maxFileSizeBytes  BigInt?
  blockedExtensions String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// task-037-D: workspace-scoped custom emoji pack. MinIO-backed (see
// scripts/setup/init-minio.sh for the bucket setup). cap = 100
// emojis per workspace is enforced at the API layer.
model CustomEmoji {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @db.Uuid
  name        String   @db.VarChar(32)
  createdBy   String   @db.Uuid
  storageKey  String
  mime        String   @db.VarChar(127)
  sizeBytes   BigInt
  createdAt   DateTime @default(now())

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User               @relation("CustomEmojiCreator", fields: [createdBy], references: [id])
  // S41 (FR-EM06): 이 커스텀 이모지를 참조하는 반응 행들. 이모지 삭제 시 각 행의
  // customEmojiId 는 SetNull 로 풀린다(반응 행 자체는 보존 — 카운트 유지 +
  // [삭제된 이모지] placeholder).
  reactions MessageReaction[]
  // S42 (FR-EM05): 이 커스텀 이모지의 별칭들. 이모지 hard delete 시 Cascade 로
  // 함께 정리된다(별칭은 이모지 없이는 무의미).
  aliases   CustomEmojiAlias[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

// S42 (D05 / FR-EM05): 커스텀 이모지 별칭. 한 CustomEmoji 가 여러 :slug: 로
// 참조될 수 있게 한다(이모지당 ≤10 — 서비스 레이어 enforce). alias 는 워크스페이스
// 내 unique 이며, CustomEmoji.name 과도 충돌하면 안 된다(서비스가 name + alias
// 양쪽을 검사). additive 신규 테이블 — 기존 row 영향 없음. CustomEmoji 삭제 시
// Cascade.
model CustomEmojiAlias {
  id            String   @id @default(uuid()) @db.Uuid
  customEmojiId String   @db.Uuid
  workspaceId   String   @db.Uuid
  alias         String   @db.VarChar(32)
  createdBy     String   @db.Uuid
  createdAt     DateTime @default(now())

  customEmoji CustomEmoji @relation(fields: [customEmojiId], references: [id], onDelete: Cascade)
  creator     User        @relation("CustomEmojiAliasCreator", fields: [createdBy], references: [id])

  @@unique([workspaceId, alias])
  @@index([customEmojiId])
}

// S42 (D05 / FR-PK03): 사용자별 이모지 개인화(스킨톤·퀵반응·최근). 서버 저장으로
// 기기 간 동기화(localStorage fallback 없음). userId unique — 사용자당 1행.
// additive 신규 테이블. defaultSkinTone 1=기본, 2-6=피츠패트릭 수정자.
// quickReactions 는 3개 고정 emoji 배열, recentEmojis 는 최대 36개(prepend+dedup).
model UserEmojiPreference {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  defaultSkinTone Int      @default(1)
  quickReactions  Json     @default("[\"👍\",\"❤️\",\"😂\"]")
  recentEmojis    Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// S42 (D05 / FR-PK04): 워크스페이스별 이모지 설정. workspaceId unique — 워크스페이스당
// 1행. quickReactions 는 워크스페이스 기본 퀵반응(UserEmojiPreference.quickReactions
// 가 없을 때의 기본값 역할). canMemberUpload=false(기본) 시 일반 MEMBER 업로드 차단
// — S41 ADMIN-only 게이트 보존(★메인루프 결정). true 면 MEMBER 도 presign/finalize
// 허용. additive 신규 테이블.
model WorkspaceEmojiConfig {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @unique @db.Uuid
  quickReactions  Json     @default("[\"👍\",\"❤️\",\"😂\"]")
  canMemberUpload Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model UserChannelReadState {
  userId                   String    @db.Uuid
  channelId                String    @db.Uuid
  // Points at an OutboxEvent.id — the last event this user has fully
  // processed client-side. Drives reconnect replay ("replay everything after
  // X"). PRESERVED in S11 — reconnect replay still keys off this column.
  lastReadEventId          String    @db.Uuid
  // S11 (FR-RT-14/19): legacy createdAt-only read threshold. PRESERVED so
  // the mention-inbox proxy (me-mentions.service) keeps working. Channel
  // unread now drives off the (createdAt, id) tuple below.
  lastReadAt               DateTime  @default(now())
  // S11 (FR-RT-19): monotonic read cursor as a sortable (createdAt, id)
  // tuple. Message.id is a RANDOM uuid (no S00 sortable-id foundation), so
  // a bare `id >` comparison is order-meaningless — we instead compare the
  // (createdAt, id) tuple, matching the canonical message sort the cursor
  // pagination already uses (messages.service). Both columns are nullable:
  // existing rows + freshly-joined channels back-fill to NULL ⇒ "every
  // message is unread", which is the intended UX.
  lastReadMessageId        String?   @db.Uuid
  lastReadMessageCreatedAt DateTime? @db.Timestamptz
  updatedAt                DateTime  @updatedAt

  @@id([userId, channelId])
  @@index([channelId])
}

// S24 (FR-RS-18): mark-all-read 직전 ChannelReadState 의 내구 스냅샷. Undo 토스트의
// "실행 취소" 가 이 스냅샷으로 채널별 lastReadMessageId 를 되돌린다(후진 허용 —
// markUnread 와 동일한 비-monotonic 경로). read-all 실행 순서:
//   (1) 현재 ChannelReadState SELECT → snapshot
//   (2) Redis(TTL 5분) + DB(이 테이블) 이중 저장 — 2단계 실패 시 ACK 미진행 + 500
//   (3) chunk(set-based) ACK UPDATE
// Redis 는 빠른 hot 경로(5분 윈도), DB 는 Redis 미스/재시작 시 폴백(durable).
// `snapshot` JSON = 채널별 { lastReadMessageId, lastReadMessageCreatedAt } 맵.
// expiresAt 정리(cron/query-time)는 DEFER(carryover) — 인덱스만 선제 존재.
model MarkAllReadSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  workspaceId String   @db.Uuid
  // 채널별 직전 커서 맵. shape: { [channelId]: { lastReadMessageId: string|null,
  // lastReadMessageCreatedAt: string|null } }. row 가 없던(커서 NULL) 채널도
  // 명시적으로 담아 복원 시 "전체 미읽"(NULL) 로 되돌린다.
  snapshot    Json
  createdAt   DateTime @default(now())
  // Redis TTL(5분)보다 길게 잡아 durable 폴백 윈도를 보장한다(서비스가 산정).
  expiresAt   DateTime @db.Timestamptz

  @@index([userId, workspaceId])
  @@index([expiresAt])
}

// task-032: Friendship — single row per directed pair. ACCEPTED +
// BLOCKED collapse to one row (vs two symmetric ones) to keep unique
// semantics tight: there can never be two ACCEPTED rows for the same
// pair. Lookup must check both (requesterId, addresseeId) and
// (addresseeId, requesterId).
model Friendship {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @db.Uuid
  addresseeId String           @db.Uuid
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

// task-026: Activity inbox read state. Keyed per-user + per-activityKey
// (synthesised from the underlying messages / reactions record), so a
// user can mark a specific mention / reply / reaction row as read
// without affecting the channel-level read state.
model UserActivityReadState {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  activityKey String
  readAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityKey])
  @@index([userId, readAt(sort: Desc)])
}

model Invite {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  code        String    @unique
  createdById String    @db.Uuid
  expiresAt   DateTime?
  maxUses     Int?
  usedCount   Int       @default(0)
  revokedAt   DateTime?
  // S67 (D13 / FR-W02·W03): 임시 멤버십 초대. true 면 이 링크로 수락한 멤버는
  // WorkspaceMember.isTemporary=true 로 기록된다(연결 종료 시 강퇴 — FR-W12 는 S70 범위).
  temporary   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
  @@index([expiresAt])
}

// S68 (D13 / FR-W04·W04a·W18): 이메일 직접 초대(보류). Invite(코드 링크)와는 별도
// 테이블이다(★Fork A — PRD 명시·링크 초대와 의미 분리). 미가입 이메일을 초대하면 이
// 행이 생기고 안내 메일이 나간다(이미 가입된 이메일은 행 없이 즉시 WorkspaceMember 생성).
// 토큰 보안(★핵심 AC): rawToken 은 이메일/링크에만 실리고 DB 엔 sha256(rawToken) =
// tokenHash(Char(64))만 저장한다(평문 금지). 수락 시 sha256 재계산 후 tokenHash 대조.
model WorkspacePendingInvite {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @db.Uuid
  email       String        @db.VarChar(254)
  // FR-W04: 직접 초대 가능한 역할은 MEMBER/GUEST 만(zod EmailInviteRoleSchema 가 강제).
  // 컬럼 자체는 WorkspaceRole enum 을 재사용한다.
  role        WorkspaceRole @default(MEMBER)
  // ★핵심 AC: sha256(rawToken) 64-hex. @unique 라 수락 조회를 tokenHash 단건으로 한다.
  tokenHash   String        @unique @db.Char(64)
  invitedById String        @db.Uuid
  expiresAt   DateTime      @db.Timestamptz(6)
  // 수락/취소 시각(soft). 둘 다 null 이면 활성 보류 초대(@@index 로 빠르게 스캔).
  acceptedAt  DateTime?     @db.Timestamptz(6)
  canceledAt  DateTime?     @db.Timestamptz(6)
  // FR-W18: 재발송 시 갱신(연장은 expiresAt). 목록 표시·재발송 쿨다운 근거로 쓴다.
  lastSentAt  DateTime      @default(now()) @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("WorkspacePendingInviteInviter", fields: [invitedById], references: [id])

  // 같은 워크스페이스에 같은 이메일은 한 행만(재초대는 기존 행 갱신). 소문자 정규화는
  // 서비스가 한다.
  @@unique([workspaceId, email])
  // FR-W18: 활성 보류 초대 목록 조회(canceledAt/acceptedAt 둘 다 null) 가속.
  @@index([workspaceId, canceledAt, acceptedAt])
  // 만료 스캔(후속 정리 배치)용.
  @@index([expiresAt])
}

// task-016-C-3: user-submitted beta feedback. Prisma models the enum
// + table; the DB-layer `char_length <= 2000` CHECK constraint lives
// in the migration SQL (Prisma doesn't emit CHECK constraints).
enum FeedbackCategory {
  BUG
  FEATURE
  OTHER
}

model Feedback {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String?          @db.Uuid
  workspaceId String?          @db.Uuid
  category    FeedbackCategory
  content     String           @db.Text
  page        String?
  userAgent   String?
  createdAt   DateTime         @default(now())

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}
