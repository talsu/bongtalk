{
  "name": "@qufox/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"node --require @swc-node/register src/main.ts\"",
    "build": "swc src -d dist --copy-files --strip-leading-paths",
    "start": "node dist/main.js",
    "lint": "eslint src --no-error-on-unmatched-pattern",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:int": "vitest run --config vitest.int.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force --skip-seed && pnpm db:seed",
    "db:seed": "node --require @swc-node/register prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@nestjs/event-emitter": "2.1.1",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.15",
    "@nestjs/platform-socket.io": "10.4.15",
    "@nestjs/websockets": "10.4.15",
    "@node-rs/argon2": "2.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "5.22.0",
    "@qufox/shared-types": "workspace:*",
    "@socket.io/redis-adapter": "8.3.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cookie-parser": "1.4.7",
    "helmet": "8.0.0",
    "ioredis": "5.4.2",
    "nestjs-pino": "4.1.0",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "pino-pretty": "11.3.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "socket.io": "4.8.1",
    "uuid": "11.0.3",
    "zxcvbn": "4.4.2"
  },
  "devDependencies": {
    "@nestjs/testing": "10.4.15",
    "@swc-node/register": "1.10.9",
    "@swc/cli": "0.5.2",
    "@swc/core": "1.9.3",
    "@types/cookie-parser": "1.4.8",
    "@types/express": "5.0.0",
    "@types/node": "20.11.30",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "@types/zxcvbn": "4.4.5",
    "nodemon": "3.1.7",
    "prisma": "5.22.0",
    "socket.io-client": "4.8.1",
    "supertest": "7.0.0",
    "testcontainers": "10.14.0",
    "typescript": "5.6.3",
    "unplugin-swc": "1.5.1",
    "vitest": "2.1.8"
  }
}
