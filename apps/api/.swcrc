{
  "$schema": "https://json.schemastore.org/swcrc",
  "sourceMaps": true,
  "module": { "type": "commonjs" },
  "jsc": {
    "target": "es2022",
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "decoratorMetadata": true,
      "legacyDecorator": true
    },
    "keepClassNames": true,
    "baseUrl": "./"
  }
}
