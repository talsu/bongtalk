# Copy to .env.deploy on the NAS (chmod 0600 admin:users).
# Consumed by compose.deploy.yml (webhook + backup-cron services).
# Kept separate from .env.prod so rotating the deploy secret does not
# require editing the application env file.

# ─── Webhook ────────────────────────────────────────────────────────────
# 32 random bytes hex. Must match the secret set on the GitHub webhook.
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=change-me-64-hex-chars

# Branch whose push events trigger a deploy. Anything else is ACK'd but
# ignored. Comma-separated list allowed.
DEPLOY_BRANCH_ALLOWLIST=main

# Bound to 127.0.0.1 inside the host network namespace; nginx proxies
# from deploy.qufox.com to this port.
WEBHOOK_PORT=9000

# Absolute path to the repo checkout on the NAS. The webhook shells out
# into this directory before running deploy scripts.
REPO_PATH=/volume2/dockers/qufox

# ─── Notifications ──────────────────────────────────────────────────────
# Optional. Empty value disables notifications entirely (stdout log
# remains). Slack incoming-webhook URL form.
SLACK_WEBHOOK_URL=

# ─── Backups ────────────────────────────────────────────────────────────
# Host path mounted into qufox-backup. Must exist and be writable by
# uid 1026 (admin). chmod 0700 recommended.
BACKUP_DIR=/volume1/backups/qufox

# Daily backups kept for N days (rotated FIFO). Weekly (Sunday) copies
# get a longer retention.
BACKUP_DAILY_KEEP=14
BACKUP_WEEKLY_KEEP=8

# Cron expression (UTC) for daily backup. Synology's own synosched
# tasks cluster around 03:00 UTC so we intentionally offset.
BACKUP_CRON='30 3 * * *'

# Cron expression for the weekly restore smoke test. Runs pg_restore
# into a throwaway container and alerts if it fails.
RESTORE_TEST_CRON='45 4 * * 0'

# ─── Rollback / image retention ─────────────────────────────────────────
# Number of historical :sha-<7char> tags to keep locally per image.
# The rest are GC'd after each deploy to keep disk usage bounded.
IMAGE_HISTORY_KEEP=10
